                showMapConfigModal: function(siteId, siteName) {
                    const mapData = db.siteMaps[siteId] || Utils.generateSiteLocation(siteId);
                    
                    const lat = prompt(`Enter latitude for ${siteName}:`, mapData.center[0]);
                    if (lat !== null) {
                        const lng = prompt(`Enter longitude for ${siteName}:`, mapData.center[1]);
                        if (lng !== null) {
                            mapData.center = [parseFloat(lat) || mapData.center[0], parseFloat(lng) || mapData.center[1]];
                            db.siteMaps[siteId] = mapData;
                            Utils.saveData();
                            Utils.showToast('Success', `Map location updated for ${siteName}`);
                            
                            if (siteId === db.currentSiteId && window.map) {
                                App.updateMapForCurrentSite();
                            }
                        }
                    }
