                populateSpeciesDropdown: function(selectId, selectedId) {
                    const select = document.getElementById(selectId);
                    if (!select) return;

                    select.innerHTML = '<option value="">None</option>';
                    
                    Utils.filterByCurrentSite(db.species).forEach(species => {
                        const option = document.createElement('option');
                        option.value = species.id;
                        option.textContent = `${species.scientificName}${species.commonName ? ` (${species.commonName})` : ''}`;
                        if (selectedId && species.id === selectedId) {
                            option.selected = true;
                        }
                        select.appendChild(option);
                    });
                },

                setupColorPicker: function(containerId, inputId, defaultColor = '#3498db') {
                    const container = document.getElementById(containerId);
                    const input = document.getElementById(inputId);
                    
                    if (!container || !input) return;

                    // Set default
                    input.value = defaultColor;

                    // Add click handlers to color pickers
                    container.querySelectorAll('.color-picker').forEach(picker => {
                        picker.classList.remove('selected');
                        if (picker.dataset.color === defaultColor) {
                            picker.classList.add('selected');
                        }

                        picker.addEventListener('click', function() {
                            container.querySelectorAll('.color-picker').forEach(p => p.classList.remove('selected'));
                            this.classList.add('selected');
                            input.value = this.dataset.color;
                        });
                    });
                },

                saveNewFeature: function() {
                    const form = document.getElementById('formAddMapFeature');
                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    const category = document.getElementById('featureCategory').value;
                    const name = document.getElementById('featureName').value;
                    const description = document.getElementById('featureDescription').value;
                    const color = document.getElementById('featureColor').value;
                    const speciesId = document.getElementById('featureSpecies').value || null;
                    const featureType = document.getElementById('featureType').value;

                    // Get coordinates
                    let coordinates;
                    if (featureType === 'polygon' || featureType === 'line') {
                        coordinates = JSON.parse(document.getElementById('featureCoordinates').value);
                    } else {
                        const lat = parseFloat(document.getElementById('featureLat').value);
                        const lng = parseFloat(document.getElementById('featureLng').value);
                        coordinates = [lat, lng];
                    }

                    // Create feature object
                    const feature = {
                        id: Utils.generateId(),
                        siteId: db.currentSiteId,
                        type: featureType,
                        category: category,
                        name: name,
                        description: description,
                        color: color,
                        speciesId: speciesId,
                        coordinates: coordinates,
                        createdAt: new Date().toISOString()
                    };

                    // Store in database
                    if (!db.mapFeatures[db.currentSiteId]) {
                        db.mapFeatures[db.currentSiteId] = { zones: [], vegetation: [], weeds: [], points: [] };
                    }

                    // Add to appropriate category
                    if (category === 'zone') {
                        db.mapFeatures[db.currentSiteId].zones.push(feature);
                    } else if (category === 'vegetation') {
                        db.mapFeatures[db.currentSiteId].vegetation.push(feature);
                    } else if (category === 'weed') {
                        db.mapFeatures[db.currentSiteId].weeds.push(feature);
                    } else {
                        db.mapFeatures[db.currentSiteId].points.push(feature);
                    }

                    // Update the layer with feature data
                    const modal = document.getElementById('modalAddMapFeature');
                    if (modal.currentLayer) {
                        modal.currentLayer.featureData = feature;
                        
                        // Update popup
                        modal.currentLayer.unbindPopup();
                        modal.currentLayer.bindPopup(this.createFeaturePopup(feature));
                    }

                    // Save to storage
                    if (Utils.saveData()) {
                        bootstrap.Modal.getInstance(modal).hide();
                        Utils.showToast('Success', 'Feature added to map');
                        this.updateMapFeaturesCount();
                    }
                },

                updateFeature: function() {
                    const form = document.getElementById('formEditMapFeature');
                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    const featureId = parseInt(document.getElementById('editFeatureId').value);
                    const feature = this.findFeatureById(featureId);
                    
                    if (!feature) return;

                    // Update properties
                    feature.name = document.getElementById('editFeatureName').value;
                    feature.category = document.getElementById('editFeatureCategory').value;
                    feature.description = document.getElementById('editFeatureDescription').value;
                    feature.color = document.getElementById('editFeatureColor').value;
                    feature.speciesId = document.getElementById('editFeatureSpecies').value || null;
                    feature.updatedAt = new Date().toISOString();

                    // Find and update the layer
                    this.updateLayerForFeature(feature);

                    // Save to storage
                    if (Utils.saveData()) {
                        bootstrap.Modal.getInstance(document.getElementById('modalEditMapFeature')).hide();
                        Utils.showToast('Success', 'Feature updated');
                        this.updateMapFeaturesCount();
                    }
                },

                deleteFeature: function() {
                    const featureId = parseInt(document.getElementById('editFeatureId').value);
                    
                    Utils.showConfirmation(
                        'Delete Feature',
                        'Are you sure you want to delete this map feature?',
                        () => {
                            this.removeFeatureFromStorage(featureId);
                            
                            // Find and remove the layer
                            this.removeLayerForFeature(featureId);
                            
                            bootstrap.Modal.getInstance(document.getElementById('modalEditMapFeature')).hide();
                            Utils.showToast('Success', 'Feature deleted');
                            this.updateMapFeaturesCount();
                        }
                    );
                },

                findFeatureById: function(featureId) {
                    const siteFeatures = db.mapFeatures[db.currentSiteId] || { zones: [], vegetation: [], weeds: [], points: [] };
                    
                    for (const category of ['zones', 'vegetation', 'weeds', 'points']) {
                        const feature = siteFeatures[category].find(f => f.id === featureId);
                        if (feature) return feature;
                    }
                    
                    return null;
                },

                removeFeatureFromStorage: function(featureId) {
                    const siteFeatures = db.mapFeatures[db.currentSiteId];
                    if (!siteFeatures) return;

                    for (const category of ['zones', 'vegetation', 'weeds', 'points']) {
                        const index = siteFeatures[category].findIndex(f => f.id === featureId);
                        if (index !== -1) {
                            siteFeatures[category].splice(index, 1);
                            break;
                        }
                    }

                    Utils.saveData();
                },

                updateLayerForFeature: function(feature) {
                    this.loadFeaturesForCurrentSite();
                },

                removeLayerForFeature: function(featureId) {
                    this.loadFeaturesForCurrentSite();
                },

                updateMapFeaturesCount: function() {
                    const siteFeatures = db.mapFeatures[db.currentSiteId] || { zones: [], vegetation: [], weeds: [], points: [] };
                    const total = siteFeatures.zones.length + siteFeatures.vegetation.length + 
                                 siteFeatures.weeds.length + siteFeatures.points.length;
                    
                    const mapFeaturesCount = document.getElementById('mapFeaturesCount');
                    if (mapFeaturesCount) mapFeaturesCount.textContent = total;
                },

                toggleEditMode: function() {
                    db.editMode = !db.editMode;
                    
                    const editModeBtn = document.getElementById('editModeBtn');
                    const mapEditMode = document.getElementById('mapEditMode');
                    
                    if (editModeBtn) {
                        if (db.editMode) {
                            editModeBtn.classList.add('active', 'btn-warning');
                            editModeBtn.classList.remove('btn-outline-warning');
                            editModeBtn.innerHTML = '<i class="bi bi-pencil-square"></i> Exit Edit Mode';
                            if (mapEditMode) mapEditMode.textContent = 'Edit Mode';
                        } else {
                            editModeBtn.classList.remove('active', 'btn-warning');
                            editModeBtn.classList.add('btn-outline-warning');
                            editModeBtn.innerHTML = '<i class="bi bi-pencil-square"></i> Edit Mode';
                            if (mapEditMode) mapEditMode.textContent = 'View Mode';
                        }
                    }

                    if (window.map && window.map.pm) {
                        if (db.editMode) {
                            window.map.pm.enableDraw('Marker');
                        } else {
                            window.map.pm.disableDraw();
                            window.map.pm.disableGlobalEditMode();
                        }
                    }

                    Utils.showToast('Info', db.editMode ? 'Edit mode enabled' : 'Edit mode disabled', 'info');
                },

                saveMap: function() {
                    if (Utils.saveData()) {
                        Utils.showToast('Success', 'Map saved successfully');
                    }
                },

                clearMap: function() {
                    Utils.showConfirmation(
                        'Clear Map',
                        'Are you sure you want to clear all custom map features? This cannot be undone.',
                        () => {
                            // Clear features for current site
                            db.mapFeatures[db.currentSiteId] = { zones: [], vegetation: [], weeds: [], points: [] };
                            
                            // Reload features (which will clear layers)
                            this.loadFeaturesForCurrentSite();
                            
                            Utils.saveData();
                            Utils.showToast('Success', 'Map cleared');
                        }
                    );
                }
            };

            // ==================== SITE MANAGEMENT FUNCTIONS ====================
            const SiteManager = {
                initSites: function() {
                    if (db.sites.length === 0) {
                        const defaultSite = {
                            id: Utils.generateId(),
                            name: "Blue Mountains Conservation Area",
                            location: "NSW, Australia",
                            area: 125,
                            description: "Mixed eucalypt forest with significant biodiversity values including several threatened species.",
                            createdAt: new Date().toISOString()
                        };
                        db.sites.push(defaultSite);
                        db.siteMaps[defaultSite.id] = Utils.generateSiteLocation(defaultSite.id);
                        db.mapFeatures[defaultSite.id] = { zones: [], vegetation: [], weeds: [], points: [] };
                        db.currentSiteId = defaultSite.id;
                    } else if (db.sites.length > 0 && !db.currentSiteId) {
                        db.currentSiteId = db.sites[0].id;
                    }
                    
                    // Ensure each site has map data
                    db.sites.forEach(site => {
                        if (!db.siteMaps[site.id]) {
                            db.siteMaps[site.id] = Utils.generateSiteLocation(site.id);
                        }
                        if (!db.mapFeatures[site.id]) {
                            db.mapFeatures[site.id] = { zones: [], vegetation: [], weeds: [], points: [] };
