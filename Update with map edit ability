                initMap: function() {
                    console.log('Initializing map...');
                    
                    const mapContainer = document.querySelector('.map-container');
                    if (!mapContainer) {
                        console.error('Map container not found');
                        return;
                    }

                    const siteId = db.currentSiteId;
                    const site = Utils.getCurrentSite();
                    
                    if (!site) {
                        mapContainer.innerHTML = '<div class="alert alert-warning">No site selected.</div>';
                        return;
                    }
                    
                    let mapData = db.siteMaps[siteId];
                    if (!mapData) {
                        mapData = Utils.generateSiteLocation(siteId);
                        db.siteMaps[siteId] = mapData;
                        Utils.saveData();
                    }
                    
                    try {
                        if (window.map) {
                            window.map.remove();
                            window.map = null;
                        }
                        
                        const mapElement = document.getElementById('map');
                        if (!mapElement) {
                            mapContainer.innerHTML = '<div id="map" style="height: 100%; width: 100%;"></div>';
                        }
                        
                        setTimeout(() => {
                            const newMapElement = document.getElementById('map');
                            if (!newMapElement) return;
                            
                            // Set explicit dimensions
                            newMapElement.style.height = '500px';
                            newMapElement.style.width = '100%';
                            
                            // Create map
                            window.map = L.map('map', {
                                center: mapData.center,
                                zoom: 13,
                                zoomControl: true
                            });

                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                                maxZoom: 19
                            }).addTo(window.map);

                            // Add main site marker
                            L.marker(mapData.center).addTo(window.map)
                                .bindPopup(`<b>${Utils.sanitizeHTML(site.name)}</b><br>${Utils.sanitizeHTML(site.location)}`)
                                .openPopup();

                            // Create base layers
                            window.zonesLayer = L.layerGroup();
                            window.vegetationLayer = L.layerGroup();
                            window.weedsLayer = L.layerGroup();
                            
                            // Add default zones
                            mapData.zones.forEach(zone => {
                                const polygon = L.polygon(zone.coords, {
                                    color: zone.color,
                                    weight: 3,
                                    opacity: 0.8,
                                    fillOpacity: 0.2
                                }).bindPopup(`<b>${zone.name}</b>`);
                                
                                window.zonesLayer.addLayer(polygon);
                            });
                            
                            // Add default vegetation markers
                            mapData.vegetationMarkers.forEach(markerData => {
                                const m = L.marker(markerData.coords, {
                                    icon: L.divIcon({
                                        className: 'custom-div-icon',
                                        html: '<div style="background-color: #27ae60; width: 10px; height: 10px; border-radius: 50%; border: 2px solid white;"></div>',
                                        iconSize: [14, 14],
                                        popupAnchor: [0, -7]
                                    })
                                }).bindPopup(`<b>Vegetation:</b> ${markerData.name}`);
                                window.vegetationLayer.addLayer(m);
                            });
                            
                            // Add default weed markers
                            mapData.weedMarkers.forEach(markerData => {
                                const m = L.marker(markerData.coords, {
                                    icon: L.divIcon({
                                        className: 'custom-div-icon',
                                        html: '<div style="background-color: #e74c3c; width: 10px; height: 10px; border-radius: 50%; border: 2px solid white;"></div>',
                                        iconSize: [14, 14],
                                        popupAnchor: [0, -7]
                                    })
                                }).bindPopup(`<b>Weed:</b> ${markerData.name}`);
                                window.weedsLayer.addLayer(m);
                            });

                            // Add zones layer by default
                            window.zonesLayer.addTo(window.map);
                            
                            // Initialize map editing
                            MapEditor.initEditing();
                            
                            // Load custom features
                            MapEditor.loadFeaturesForCurrentSite();
                            
                            // Set toggle button states
                            const zoneToggle = document.getElementById('zoneToggle');
                            const vegToggle = document.getElementById('vegetationToggle');
                            const weedsToggle = document.getElementById('weedsToggle');
                            
                            if (zoneToggle) {
                                zoneToggle.classList.add('active');
                                zoneToggle.setAttribute('aria-pressed', 'true');
                            }
                            if (vegToggle) {
                                vegToggle.classList.remove('active');
                                vegToggle.setAttribute('aria-pressed', 'false');
                            }
                            if (weedsToggle) {
                                weedsToggle.classList.remove('active');
                                weedsToggle.setAttribute('aria-pressed', 'false');
                            }
                            
                            // Force map resize after a short delay
                            setTimeout(() => {
                                if (window.map) {
                                    window.map.invalidateSize(true);
                                    console.log('Map invalidateSize called');
                                }
                            }, 300);
                            
                            console.log('Map updated successfully for site:', site.name);
                            
                        }, 200);

                    } catch (error) {
                        console.error('Error updating map:', error);
                        const mapContainer = document.querySelector('.map-container');
                        if (mapContainer) {
                            mapContainer.innerHTML = '<div class="alert alert-warning">Map could not be updated. Please check the console for details.</div>';
                        }
                    }
