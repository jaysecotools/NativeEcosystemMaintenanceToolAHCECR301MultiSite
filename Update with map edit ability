    <!-- FullCalendar JS -->
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    <script>
        (function() {
            'use strict';

            // ==================== CONSTANTS ====================
            const STORAGE_KEYS = {
                ASSESSMENTS: 'ecosystem_assessments',
                SPECIES: 'ecosystem_species',
                ACTIVITIES: 'ecosystem_activities',
                MONITORING: 'ecosystem_monitoring',
                REPORTS: 'ecosystem_reports',
                FAUNA_SIGHTINGS: 'ecosystem_fauna_sightings',
                VEGETATION_SURVEYS: 'ecosystem_vegetation_surveys',
                COMPLIANCE: 'ecosystem_compliance',
                SETTINGS: 'ecosystem_settings',
                SITES: 'ecosystem_sites',
                SITE_MAPS: 'ecosystem_site_maps',
                MAP_FEATURES: 'ecosystem_map_features'
            };

            // ==================== INITIAL DATA ====================
            const db = {
                assessments: [],
                species: [],
                activities: [],
                monitoring: [],
                reports: [],
                faunaSightings: [],
                vegetationSurveys: [],
                complianceChecklist: [
                    { id: 1, requirement: "Identified all relevant legislation", compliant: "", evidence: "", notes: "" },
                    { id: 2, requirement: "Assessed impacts on protected matters", compliant: "", evidence: "", notes: "" },
                    { id: 3, requirement: "Obtained necessary permits/approvals", compliant: "", evidence: "", notes: "" },
                    { id: 4, requirement: "Implemented required protections", compliant: "", evidence: "", notes: "" },
                    { id: 5, requirement: "Maintained required records", compliant: "", evidence: "", notes: "" }
                ],
                sites: [],
                siteMaps: {},
                mapFeatures: {},
                settings: {
                    userProfile: {
                        name: "John Doe",
                        email: "john.doe@example.com",
                        role: "ecologist"
                    }
                },
                currentSiteId: null,
                editMode: false
            };

            // ==================== UTILITY FUNCTIONS ====================
            const Utils = {
                parseJSON: function(key, defaultValue) {
                    try {
                        const item = localStorage.getItem(key);
                        return item ? JSON.parse(item) : defaultValue;
                    } catch (e) {
                        console.error(`Error parsing ${key}:`, e);
                        return defaultValue;
                    }
                },

                saveData: function() {
                    try {
                        localStorage.setItem(STORAGE_KEYS.ASSESSMENTS, JSON.stringify(db.assessments));
                        localStorage.setItem(STORAGE_KEYS.SPECIES, JSON.stringify(db.species));
                        localStorage.setItem(STORAGE_KEYS.ACTIVITIES, JSON.stringify(db.activities));
                        localStorage.setItem(STORAGE_KEYS.MONITORING, JSON.stringify(db.monitoring));
                        localStorage.setItem(STORAGE_KEYS.REPORTS, JSON.stringify(db.reports));
                        localStorage.setItem(STORAGE_KEYS.FAUNA_SIGHTINGS, JSON.stringify(db.faunaSightings));
                        localStorage.setItem(STORAGE_KEYS.VEGETATION_SURVEYS, JSON.stringify(db.vegetationSurveys));
                        localStorage.setItem(STORAGE_KEYS.COMPLIANCE, JSON.stringify(db.complianceChecklist));
                        localStorage.setItem(STORAGE_KEYS.SETTINGS, JSON.stringify(db.settings));
                        localStorage.setItem(STORAGE_KEYS.SITES, JSON.stringify(db.sites));
                        localStorage.setItem(STORAGE_KEYS.SITE_MAPS, JSON.stringify(db.siteMaps));
                        localStorage.setItem(STORAGE_KEYS.MAP_FEATURES, JSON.stringify(db.mapFeatures));
                        return true;
                    } catch (e) {
                        console.error('Error saving data:', e);
                        this.showToast('Error', 'Failed to save data. Storage may be full.', 'error');
                        return false;
                    }
                },

                loadData: function() {
                    db.assessments = this.parseJSON(STORAGE_KEYS.ASSESSMENTS, []);
                    db.species = this.parseJSON(STORAGE_KEYS.SPECIES, []);
                    db.activities = this.parseJSON(STORAGE_KEYS.ACTIVITIES, []);
                    db.monitoring = this.parseJSON(STORAGE_KEYS.MONITORING, []);
                    db.reports = this.parseJSON(STORAGE_KEYS.REPORTS, []);
                    db.faunaSightings = this.parseJSON(STORAGE_KEYS.FAUNA_SIGHTINGS, []);
                    db.vegetationSurveys = this.parseJSON(STORAGE_KEYS.VEGETATION_SURVEYS, []);
                    db.complianceChecklist = this.parseJSON(STORAGE_KEYS.COMPLIANCE, db.complianceChecklist);
                    db.settings = this.parseJSON(STORAGE_KEYS.SETTINGS, db.settings);
                    db.sites = this.parseJSON(STORAGE_KEYS.SITES, []);
                    db.siteMaps = this.parseJSON(STORAGE_KEYS.SITE_MAPS, {});
                    db.mapFeatures = this.parseJSON(STORAGE_KEYS.MAP_FEATURES, {});
                    
                    // Initialize mapFeatures for existing sites if needed
                    db.sites.forEach(site => {
                        if (!db.mapFeatures[site.id]) {
                            db.mapFeatures[site.id] = { zones: [], vegetation: [], weeds: [], points: [] };
                        }
                    });
                },

                sanitizeHTML: function(str) {
                    if (!str) return '';
                    const div = document.createElement('div');
                    div.textContent = str;
                    return div.innerHTML;
                },

                formatDate: function(dateString) {
                    if (!dateString) return 'Not specified';
                    try {
                        const date = new Date(dateString);
                        if (isNaN(date.getTime())) return 'Invalid date';
                        return date.toLocaleDateString('en-AU', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric'
                        });
                    } catch (e) {
                        return dateString;
                    }
                },

                formatDateTime: function(dateTimeString) {
                    if (!dateTimeString) return 'Not specified';
                    try {
                        const date = new Date(dateTimeString);
                        if (isNaN(date.getTime())) return 'Invalid date';
                        return date.toLocaleDateString('en-AU', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        });
                    } catch (e) {
                        return dateTimeString;
                    }
                },

                capitalize: function(str) {
                    if (!str) return '';
                    return str.charAt(0).toUpperCase() + str.slice(1);
                },

                showToast: function(title, message, type = 'success') {
                    const container = document.getElementById('toastContainer');
                    if (!container) return;

                    const toastId = 'toast-' + Date.now();
                    const bgClass = type === 'success' ? 'bg-success' :
                                   type === 'error' ? 'bg-danger' :
                                   type === 'warning' ? 'bg-warning' : 'bg-info';

                    const toastHtml = `
                        <div id="${toastId}" class="toast ${bgClass} text-white fade show" role="alert" aria-live="assertive" aria-atomic="true">
                            <div class="toast-header ${bgClass} text-white">
                                <strong class="me-auto">${Utils.sanitizeHTML(title)}</strong>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                            </div>
                            <div class="toast-body">
                                ${Utils.sanitizeHTML(message)}
                            </div>
                        </div>
                    `;

                    container.insertAdjacentHTML('beforeend', toastHtml);
                    const toastElement = document.getElementById(toastId);
                    const toast = new bootstrap.Toast(toastElement, { delay: 5000 });
                    toast.show();

                    toastElement.addEventListener('hidden.bs.toast', function() {
                        this.remove();
                    });
                },

                showConfirmation: function(title, message, onConfirm) {
                    const modalElement = document.getElementById('modalConfirm');
                    if (!modalElement) return;
                    
                    const modal = new bootstrap.Modal(modalElement);
                    const confirmBody = document.getElementById('confirmModalBody');
                    const confirmLabel = document.getElementById('modalConfirmLabel');
                    
                    if (confirmBody) confirmBody.innerHTML = this.sanitizeHTML(message);
                    if (confirmLabel) confirmLabel.innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i>${this.sanitizeHTML(title)}`;
                    
                    const confirmBtn = document.getElementById('confirmActionBtn');
                    if (!confirmBtn) return;
                    
                    const newBtn = confirmBtn.cloneNode(true);
                    confirmBtn.parentNode.replaceChild(newBtn, confirmBtn);
                    newBtn.id = 'confirmActionBtn';
                    
                    newBtn.addEventListener('click', function() {
                        onConfirm();
                        modal.hide();
                    });
                    
                    modal.show();
                },

                generateId: function() {
                    return Date.now() + Math.floor(Math.random() * 1000);
                },

                filterByCurrentSite: function(data) {
                    if (!db.currentSiteId) return [];
                    return data.filter(item => item.siteId === db.currentSiteId);
                },

                getCurrentSite: function() {
                    return db.sites.find(site => site.id === db.currentSiteId);
                },

                generateSiteLocation: function(siteId) {
                    const baseLat = -33.4000;
                    const baseLng = 150.3000;
                    
                    const idNum = typeof siteId === 'number' ? siteId : 
                                 (typeof siteId === 'string' ? parseInt(siteId) || 0 : 0);
                    
                    const latOffset = (idNum % 10) * 0.05;
                    const lngOffset = Math.floor(idNum / 10) % 10 * 0.05;
                    
                    return {
                        center: [baseLat + latOffset, baseLng + lngOffset],
                        zones: [
                            {
                                name: 'Zone 1 - Native Forest',
                                coords: [
                                    [baseLat - 0.01 + latOffset, baseLng - 0.01 + lngOffset],
                                    [baseLat - 0.01 + latOffset, baseLng + 0.01 + lngOffset],
                                    [baseLat + 0.01 + latOffset, baseLng + 0.01 + lngOffset],
                                    [baseLat + 0.01 + latOffset, baseLng - 0.01 + lngOffset]
                                ],
                                color: '#3498db'
                            },
                            {
                                name: 'Zone 2 - Wetland Area',
                                coords: [
                                    [baseLat + 0.02 + latOffset, baseLng - 0.015 + lngOffset],
                                    [baseLat + 0.02 + latOffset, baseLng + 0.005 + lngOffset],
                                    [baseLat + 0.04 + latOffset, baseLng + 0.005 + lngOffset],
                                    [baseLat + 0.04 + latOffset, baseLng - 0.015 + lngOffset]
                                ],
                                color: '#27ae60'
                            },
                            {
                                name: 'Zone 3 - Weed Control Area',
                                coords: [
                                    [baseLat - 0.03 + latOffset, baseLng + 0.02 + lngOffset],
                                    [baseLat - 0.03 + latOffset, baseLng + 0.04 + lngOffset],
                                    [baseLat - 0.01 + latOffset, baseLng + 0.04 + lngOffset],
                                    [baseLat - 0.01 + latOffset, baseLng + 0.02 + lngOffset]
                                ],
                                color: '#e74c3c'
                            }
                        ],
                        vegetationMarkers: [
                            { name: 'Eucalyptus pauciflora (Snow Gum)', coords: [baseLat - 0.005 + latOffset, baseLng + lngOffset] },
                            { name: 'Acacia melanoxylon (Blackwood)', coords: [baseLat - 0.004 + latOffset, baseLng + 0.002 + lngOffset] },
                            { name: 'Banksia marginata (Silver Banksia)', coords: [baseLat - 0.006 + latOffset, baseLng - 0.001 + lngOffset] }
                        ],
                        weedMarkers: [
                            { name: 'Rubus fruticosus (Blackberry)', coords: [baseLat - 0.025 + latOffset, baseLng + 0.025 + lngOffset] },
                            { name: 'Lantana camara (Lantana)', coords: [baseLat - 0.024 + latOffset, baseLng + 0.027 + lngOffset] },
                            { name: 'Ulex europaeus (Gorse)', coords: [baseLat - 0.026 + latOffset, baseLng + 0.026 + lngOffset] }
                        ]
                    };
                },

                getSiteHealthData: function(siteId) {
                    const siteAssessments = db.assessments.filter(a => a.siteId === siteId);
                    
                    let healthData = {
                        biodiversity: 78,
                        nativeCover: 65,
                        weedPressure: 22,
                        erosion: 15,
                        faunaActivity: 70,
                        waterQuality: 85,
                        previousBiodiversity: 72,
                        previousNativeCover: 60,
                        previousWeedPressure: 28,
                        previousErosion: 18,
                        previousFaunaActivity: 65,
                        previousWaterQuality: 80
                    };
                    
                    if (siteAssessments.length > 0) {
                        const sorted = [...siteAssessments].sort((a, b) => new Date(b.date) - new Date(a.date));
                        const latest = sorted[0];
                        const previous = sorted[1] || sorted[0];
                        
                        const healthScore = (health) => {
                            switch(health) {
                                case 'excellent': return 90;
                                case 'good': return 75;
                                case 'fair': return 55;
                                case 'poor': return 30;
                                case 'degraded': return 15;
                                default: return 50;
                            }
                        };
                        
                        const latestScore = healthScore(latest.health);
                        const previousScore = healthScore(previous.health);
                        
                        healthData = {
                            biodiversity: latestScore,
                            nativeCover: latestScore - (latest.threats && latest.threats.includes('weeds') ? 10 : 0),
                            weedPressure: 100 - latestScore + (latest.threats && latest.threats.includes('weeds') ? 20 : 10),
                            erosion: latest.threats && latest.threats.includes('erosion') ? 40 : 15,
                            faunaActivity: latestScore - 5,
                            waterQuality: latest.components && latest.components.includes('water') ? latestScore : 70,
                            previousBiodiversity: previousScore,
                            previousNativeCover: previousScore - (previous.threats && previous.threats.includes('weeds') ? 10 : 0),
                            previousWeedPressure: 100 - previousScore + (previous.threats && previous.threats.includes('weeds') ? 20 : 10),
                            previousErosion: previous.threats && previous.threats.includes('erosion') ? 40 : 15,
                            previousFaunaActivity: previousScore - 5,
                            previousWaterQuality: previous.components && previous.components.includes('water') ? previousScore : 70
                        };
                        
                        Object.keys(healthData).forEach(key => {
                            healthData[key] = Math.min(100, Math.max(0, healthData[key]));
                        });
                    }
                    
                    return healthData;
                }
            };

