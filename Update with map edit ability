                    const zoneToggle = document.getElementById('zoneToggle');
                    const vegToggle = document.getElementById('vegetationToggle');
                    const weedsToggle = document.getElementById('weedsToggle');

                    if (zoneToggle && zoneToggle.classList.contains('active')) {
