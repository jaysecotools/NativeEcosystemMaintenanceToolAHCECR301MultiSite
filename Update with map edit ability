                showEditSiteModal: function(site) {
                    const editSiteId = document.getElementById('editSiteId');
                    const editSiteName = document.getElementById('editSiteName');
                    const editSiteLocation = document.getElementById('editSiteLocation');
                    const editSiteArea = document.getElementById('editSiteArea');
                    const editSiteDescription = document.getElementById('editSiteDescription');
                    
                    if (editSiteId) editSiteId.value = site.id;
                    if (editSiteName) editSiteName.value = site.name;
                    if (editSiteLocation) editSiteLocation.value = site.location;
                    if (editSiteArea) editSiteArea.value = site.area;
                    if (editSiteDescription) editSiteDescription.value = site.description;
                    
                    new bootstrap.Modal(document.getElementById('modalEditSite')).show();
