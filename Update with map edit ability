                createFeaturePopup: function(feature) {
                    const species = feature.speciesId ? db.species.find(s => s.id === feature.speciesId) : null;
                    
                    return `
                        <div class="feature-popup">
                            <h6>${Utils.sanitizeHTML(feature.name)}</h6>
                            <p><strong>Category:</strong> ${Utils.capitalize(feature.category)}</p>
                            ${feature.description ? `<p>${Utils.sanitizeHTML(feature.description)}</p>` : ''}
                            ${species ? `<p><strong>Species:</strong> ${Utils.sanitizeHTML(species.scientificName)}</p>` : ''}
                            <button class="btn btn-sm btn-outline-primary edit-feature" data-id="${feature.id}">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                        </div>
                    `;
                },

                onFeatureCreated: function(e) {
                    if (!db.editMode) {
                        // If not in edit mode, remove the created feature
                        window.map.pm.removeLayer(e.layer);
                        Utils.showToast('Info', 'Enable Edit Mode to add features', 'info');
                        return;
                    }

                    const layer = e.layer;
                    const shape = e.shape;

                    // Determine feature type
                    let featureType = 'point';
                    if (shape === 'Polygon' || shape === 'Rectangle' || shape === 'Circle') {
                        featureType = 'polygon';
                    } else if (shape === 'Line') {
                        featureType = 'line';
                    } else {
                        featureType = 'point';
                    }

                    // Get coordinates
                    let coordinates;
                    if (featureType === 'polygon') {
                        coordinates = layer.getLatLngs()[0].map(latlng => [latlng.lat, latlng.lng]);
                    } else if (featureType === 'line') {
                        coordinates = layer.getLatLngs().map(latlng => [latlng.lat, latlng.lng]);
                    } else {
                        const latlng = layer.getLatLng();
                        coordinates = [latlng.lat, latlng.lng];
                    }

                    // Store feature data temporarily
                    layer.featureData = {
                        id: Utils.generateId(),
                        type: featureType,
                        coordinates: coordinates,
                        category: 'point-of-interest',
                        name: 'New Feature',
                        description: '',
                        color: '#f1c40f',
                        speciesId: null,
                        createdAt: new Date().toISOString()
                    };

                    // Open modal to edit feature details
                    this.showAddFeatureModal(layer);
                },

                onFeatureEdited: function(e) {
                    if (!db.editMode) return;

                    const layer = e.layer;
                    if (layer.featureData) {
                        // Update coordinates based on new shape
                        if (layer.featureData.type === 'polygon') {
                            layer.featureData.coordinates = layer.getLatLngs()[0].map(latlng => [latlng.lat, latlng.lng]);
                        } else if (layer.featureData.type === 'line') {
                            layer.featureData.coordinates = layer.getLatLngs().map(latlng => [latlng.lat, latlng.lng]);
                        } else {
                            const latlng = layer.getLatLng();
                            layer.featureData.coordinates = [latlng.lat, latlng.lng];
                        }
                        
                        layer.featureData.updatedAt = new Date().toISOString();
                    }
                },

                onFeatureRemoved: function(e) {
                    if (!db.editMode) return;

                    const layer = e.layer;
                    if (layer.featureData) {
                        this.removeFeatureFromStorage(layer.featureData.id);
                    }
                },

