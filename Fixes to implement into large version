                    // Create new chart
                    try {
                        window.healthChart = new Chart(ctx, {
                            type: 'radar',
                            data: {
                                labels: ['Biodiversity', 'Native Cover', 'Weed Pressure', 'Erosion', 'Fauna Activity', 'Water Quality'],
                                datasets: [{
