                        const id = parseInt(select.dataset.id);
                        const item = db.complianceChecklist.find(i => i.id === id);
                        if (item) item.compliant = select.value;
                    });

                    document.querySelectorAll('.compliance-evidence').forEach(input => {
                        const id = parseInt(input.dataset.id);
                        const item = db.complianceChecklist.find(i => i.id === id);
                        if (item) item.evidence = input.value;
                    });

                    if (Utils.saveData()) {
                        Utils.showToast('Success', 'Compliance checklist saved');
                        this.loadDashboard();
                    }
                },

                loadSettings: function() {
                    const userName = document.getElementById('settingsUserName');
                    const userEmail = document.getElementById('settingsUserEmail');
                    const userRole = document.getElementById('settingsUserRole');
                    
                    if (userName) userName.value = db.settings.userProfile.name || '';
                    if (userEmail) userEmail.value = db.settings.userProfile.email || '';
                    if (userRole) userRole.value = db.settings.userProfile.role || '';
                },

                saveUserProfile: function(e) {
                    e.preventDefault();
                    const form = document.getElementById('settingsUserProfileForm');
                    
                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    db.settings.userProfile = {
                        name: document.getElementById('settingsUserName').value,
                        email: document.getElementById('settingsUserEmail').value,
                        role: document.getElementById('settingsUserRole').value
                    };

                    if (Utils.saveData()) {
                        Utils.showToast('Success', 'Profile updated');
                        form.classList.remove('was-validated');
                    }
                },

                changePassword: function(e) {
                    e.preventDefault();
                    const form = document.getElementById('settingsPasswordForm');
                    
                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    const newPass = document.getElementById('settingsNewPassword').value;
                    const confirmPass = document.getElementById('settingsConfirmPassword').value;

                    if (newPass !== confirmPass) {
                        document.getElementById('settingsConfirmPassword').classList.add('is-invalid');
                        return;
                    }

                    Utils.showToast('Success', 'Password changed successfully');
                    form.reset();
                    form.classList.remove('was-validated');
                },

                exportAllData: function() {
                    const exportData = {
                        assessments: db.assessments,
                        species: db.species,
                        activities: db.activities,
                        monitoring: db.monitoring,
                        reports: db.reports,
                        faunaSightings: db.faunaSightings,
                        vegetationSurveys: db.vegetationSurveys,
                        complianceChecklist: db.complianceChecklist,
                        settings: db.settings,
                        sites: db.sites,
                        siteMaps: db.siteMaps,
                        mapFeatures: db.mapFeatures,
                        exportDate: new Date().toISOString(),
                        version: '1.0.0 (Multi-site with Map Editing)'
                    };

                    const dataStr = JSON.stringify(exportData, null, 2);
                    const blob = new Blob([dataStr], { type: 'application/json' });
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `ecosystem-data-${new Date().toISOString().split('T')[0]}.json`;
                    a.click();
                    window.URL.revokeObjectURL(url);

                    Utils.showToast('Success', 'Data exported successfully');
                },

                backupDatabase: function() {
                    this.exportAllData();
                    localStorage.setItem('lastBackup', new Date().toLocaleString());
                    const lastBackupInfo = document.getElementById('lastBackupInfo');
                    if (lastBackupInfo) lastBackupInfo.textContent = new Date().toLocaleString();
                    Utils.showToast('Info', 'Backup created', 'info');
                },

                resetTestData: function() {
                    Utils.showConfirmation(
                        'Reset Test Data',
                        'Are you sure you want to reset all test data? This will restore the initial sample data and cannot be undone.',
                        () => {
                            localStorage.clear();
                            
                            db.assessments = [];
                            db.species = [];
                            db.activities = [];
                            db.monitoring = [];
                            db.reports = [];
                            db.faunaSightings = [];
                            db.vegetationSurveys = [];
                            db.complianceChecklist = [
                                { id: 1, requirement: "Identified all relevant legislation", compliant: "", evidence: "", notes: "" },
                                { id: 2, requirement: "Assessed impacts on protected matters", compliant: "", evidence: "", notes: "" },
                                { id: 3, requirement: "Obtained necessary permits/approvals", compliant: "", evidence: "", notes: "" },
                                { id: 4, requirement: "Implemented required protections", compliant: "", evidence: "", notes: "" },
                                { id: 5, requirement: "Maintained required records", compliant: "", evidence: "", notes: "" }
                            ];
                            db.settings = {
                                userProfile: {
                                    name: "John Doe",
                                    email: "john.doe@example.com",
                                    role: "ecologist"
                                }
                            };
                            db.sites = [];
                            db.siteMaps = {};
                            db.mapFeatures = {};
                            db.currentSiteId = null;
                            
                            SiteManager.initSites();
                            this.loadInitialData();
                            
                            SiteManager.loadSiteSelector();
                            this.loadAllData();
                            
                            if (window.calendar) {
                                window.calendar.refetchEvents();
                            }
                            
                            if (window.map) {
                                window.map.remove();
                                this.initMap();
                            }
                            
                            Utils.showToast('Success', 'Test data has been reset');
                        }
                    );
                },

                saveFaunaSighting: function() {
                    const form = document.getElementById('formFaunaSighting');
                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    const newSighting = {
                        id: Utils.generateId(),
                        siteId: db.currentSiteId,
                        speciesId: parseInt(document.getElementById('faunaSpecies').value),
                        date: document.getElementById('faunaDate').value,
                        location: document.getElementById('faunaLocation').value,
                        observer: document.getElementById('faunaObserver').value,
                        count: parseInt(document.getElementById('faunaCount').value) || 1,
                        behavior: document.getElementById('faunaBehavior').value,
                        photos: [],
                        notes: document.getElementById('faunaNotes').value,
                        createdAt: new Date().toISOString()
                    };

                    db.faunaSightings.push(newSighting);

                    const species = db.species.find(s => s.id === newSighting.speciesId);
                    if (species) {
                        species.lastObserved = newSighting.date;
                    }

                    if (Utils.saveData()) {
                        form.reset();
                        form.classList.remove('was-validated');
                        const preview = document.getElementById('faunaPhotoPreview');
                        if (preview) preview.innerHTML = '';
                        
                        bootstrap.Modal.getInstance(document.getElementById('modalFaunaSighting')).hide();
                        Utils.showToast('Success', 'Fauna sighting saved');
                        
                        this.loadSpecies();
                    }
                },

                saveVegetationSurvey: function() {
                    const form = document.getElementById('formVegetationSurvey');
                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    const speciesSelect = document.getElementById('vegetationSpecies');
                    const species = speciesSelect ? Array.from(speciesSelect.selectedOptions).map(opt => parseInt(opt.value)) : [];

                    const newSurvey = {
                        id: Utils.generateId(),
                        siteId: db.currentSiteId,
                        date: document.getElementById('vegetationDate').value,
                        location: document.getElementById('vegetationLocation').value,
                        observer: document.getElementById('vegetationObserver').value,
                        species: species,
                        nativeCover: parseInt(document.getElementById('vegetationCover').value) || 0,
                        weedCover: parseInt(document.getElementById('vegetationWeedCover').value) || 0,
                        health: document.getElementById('vegetationHealth').value,
                        findings: document.getElementById('vegetationFindings').value,
                        photos: [],
                        notes: document.getElementById('vegetationNotes').value,
                        createdAt: new Date().toISOString()
                    };

                    db.vegetationSurveys.push(newSurvey);

                    species.forEach(id => {
                        const s = db.species.find(sp => sp.id === id);
                        if (s) s.lastObserved = newSurvey.date;
                    });

                    if (Utils.saveData()) {
                        form.reset();
                        form.classList.remove('was-validated');
                        const preview = document.getElementById('vegetationPhotoPreview');
                        if (preview) preview.innerHTML = '';
                        
                        bootstrap.Modal.getInstance(document.getElementById('modalVegetationSurvey')).hide();
                        Utils.showToast('Success', 'Vegetation survey saved');
                        
                        this.loadSpecies();
                    }
                },

                setupEventListeners: function() {
                    const siteSelector = document.getElementById('siteSelector');
                    if (siteSelector) {
                        siteSelector.addEventListener('change', (e) => {
                            const siteId = parseInt(e.target.value);
                            if (siteId && siteId !== db.currentSiteId) {
                                const site = db.sites.find(s => s.id === siteId);
                                if (site) {
                                    SiteManager.promptSwitchSite(siteId, site.name);
                                }
                            }
                        });
                    }

                    const confirmSwitchBtn = document.getElementById('confirmSwitchSiteBtn');
                    if (confirmSwitchBtn) {
                        confirmSwitchBtn.addEventListener('click', () => {
                            const siteId = parseInt(document.getElementById('switchTargetSiteId').value);
                            SiteManager.switchSite(siteId);
                        });
                    }

                    const saveSiteBtn = document.getElementById('saveSiteBtn');
                    if (saveSiteBtn) saveSiteBtn.addEventListener('click', () => SiteManager.saveSite());
                    
                    const updateSiteBtn = document.getElementById('updateSiteBtn');
                    if (updateSiteBtn) updateSiteBtn.addEventListener('click', () => SiteManager.updateSite());
                    
                    const saveAssessmentBtn = document.getElementById('saveAssessmentBtn');
                    if (saveAssessmentBtn) saveAssessmentBtn.addEventListener('click', () => this.saveAssessment());
                    
                    const saveActivityBtn = document.getElementById('saveActivityBtn');
                    if (saveActivityBtn) saveActivityBtn.addEventListener('click', () => this.saveActivity());
                    
                    const saveSpeciesBtn = document.getElementById('saveSpeciesBtn');
                    if (saveSpeciesBtn) saveSpeciesBtn.addEventListener('click', () => this.saveSpecies());
                    
                    const saveMonitoringBtn = document.getElementById('saveMonitoringBtn');
                    if (saveMonitoringBtn) saveMonitoringBtn.addEventListener('click', () => this.saveMonitoring());
                    
                    const saveFaunaSightingBtn = document.getElementById('saveFaunaSightingBtn');
                    if (saveFaunaSightingBtn) saveFaunaSightingBtn.addEventListener('click', () => this.saveFaunaSighting());
                    
                    const saveVegetationSurveyBtn = document.getElementById('saveVegetationSurveyBtn');
                    if (saveVegetationSurveyBtn) saveVegetationSurveyBtn.addEventListener('click', () => this.saveVegetationSurvey());
                    
                    const saveComplianceBtn = document.getElementById('saveComplianceBtn');
                    if (saveComplianceBtn) saveComplianceBtn.addEventListener('click', () => this.saveComplianceChecklist());
                    
                    const generateReportBtn = document.getElementById('generateReportBtn');
                    if (generateReportBtn) generateReportBtn.addEventListener('click', () => this.generateReportFromModal());

                    // Add event listeners for generate report buttons
                    document.querySelectorAll('.generate-report-btn').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            const type = e.target.dataset.type;
                            this.generateReport(type);
                        });
                    });

                    const settingsUserProfileForm = document.getElementById('settingsUserProfileForm');
                    if (settingsUserProfileForm) {
                        settingsUserProfileForm.addEventListener('submit', (e) => this.saveUserProfile(e));
                    }
                    
                    const settingsPasswordForm = document.getElementById('settingsPasswordForm');
                    if (settingsPasswordForm) {
                        settingsPasswordForm.addEventListener('submit', (e) => this.changePassword(e));
                    }

                    const exportAllDataBtn = document.getElementById('exportAllDataBtn');
                    if (exportAllDataBtn) exportAllDataBtn.addEventListener('click', () => this.exportAllData());
                    
                    const backupDatabaseBtn = document.getElementById('backupDatabaseBtn');
                    if (backupDatabaseBtn) backupDatabaseBtn.addEventListener('click', () => this.backupDatabase());
                    
                    const resetTestDataBtn = document.getElementById('resetTestDataBtn');
                    if (resetTestDataBtn) resetTestDataBtn.addEventListener('click', () => this.resetTestData());

                    const exportDashboardBtn = document.getElementById('exportDashboardBtn');
                    if (exportDashboardBtn) exportDashboardBtn.addEventListener('click', () => this.exportAllData());
                    
                    const printDashboardBtn = document.getElementById('printDashboardBtn');
                    if (printDashboardBtn) printDashboardBtn.addEventListener('click', () => window.print());
                    
                    const exportSpeciesBtn = document.getElementById('exportSpeciesBtn');
                    if (exportSpeciesBtn) exportSpeciesBtn.addEventListener('click', () => this.exportAllData());
                    
                    const printSpeciesBtn = document.getElementById('printSpeciesBtn');
                    if (printSpeciesBtn) printSpeciesBtn.addEventListener('click', () => window.print());

                    const viewAllFaunaBtn = document.getElementById('viewAllFaunaBtn');
                    if (viewAllFaunaBtn) {
                        viewAllFaunaBtn.addEventListener('click', () => {
                            const monitoringTab = document.querySelector('button[data-bs-target="#monitoring"]');
                            if (monitoringTab) monitoringTab.click();
                        });
                    }
                    
                    const viewAllVegetationBtn = document.getElementById('viewAllVegetationBtn');
                    if (viewAllVegetationBtn) {
                        viewAllVegetationBtn.addEventListener('click', () => {
                            const monitoringTab = document.querySelector('button[data-bs-target="#monitoring"]');
                            if (monitoringTab) monitoringTab.click();
                        });
                    }

                    const printAssessmentBtn = document.getElementById('printAssessmentBtn');
                    if (printAssessmentBtn) printAssessmentBtn.addEventListener('click', () => window.print());
                    
                    const printSpeciesDetailsBtn = document.getElementById('printSpeciesDetailsBtn');
                    if (printSpeciesDetailsBtn) printSpeciesDetailsBtn.addEventListener('click', () => window.print());
                    
                    const printActivityBtn = document.getElementById('printActivityBtn');
                    if (printActivityBtn) printActivityBtn.addEventListener('click', () => window.print());
                    
                    const printMonitoringBtn = document.getElementById('printMonitoringBtn');
                    if (printMonitoringBtn) printMonitoringBtn.addEventListener('click', () => window.print());

                    const generateComplianceReportBtn = document.getElementById('generateComplianceReportBtn');
                    if (generateComplianceReportBtn) {
                        generateComplianceReportBtn.addEventListener('click', () => this.generateReport('compliance'));
                    }

                    // Map editing event listeners
                    const editModeBtn = document.getElementById('editModeBtn');
                    if (editModeBtn) {
                        editModeBtn.addEventListener('click', () => MapEditor.toggleEditMode());
                    }

                    const saveMapBtn = document.getElementById('saveMapBtn');
                    if (saveMapBtn) {
                        saveMapBtn.addEventListener('click', () => MapEditor.saveMap());
                    }

                    const clearMapBtn = document.getElementById('clearMapBtn');
                    if (clearMapBtn) {
                        clearMapBtn.addEventListener('click', () => MapEditor.clearMap());
                    }

                    // Map feature modal buttons
                    const saveMapFeatureBtn = document.getElementById('saveMapFeatureBtn');
                    if (saveMapFeatureBtn) {
                        saveMapFeatureBtn.addEventListener('click', () => MapEditor.saveNewFeature());
                    }

                    const updateMapFeatureBtn = document.getElementById('updateMapFeatureBtn');
                    if (updateMapFeatureBtn) {
                        updateMapFeatureBtn.addEventListener('click', () => MapEditor.updateFeature());
                    }

                    const deleteMapFeatureBtn = document.getElementById('deleteMapFeatureBtn');
                    if (deleteMapFeatureBtn) {
                        deleteMapFeatureBtn.addEventListener('click', () => MapEditor.deleteFeature());
                    }

                    // Delegate click events for feature edit buttons
                    document.addEventListener('click', (e) => {
                        if (e.target.closest('.edit-feature')) {
                            const featureId = parseInt(e.target.closest('.edit-feature').dataset.id);
                            MapEditor.showEditFeatureModal(featureId);
                        }
                    });

                    document.querySelectorAll('[data-bs-toggle="tab"]').forEach(tab => {
                        tab.addEventListener('shown.bs.tab', (e) => {
                            const target = e.target.getAttribute('data-bs-target');
                            
                            if (target === '#dashboard') {
                                this.loadDashboard();
                            } else if (target === '#site-assessment') {
                                this.loadAssessments();
                            } else if (target === '#maintenance-plan') {
                                this.loadActivities();
                                if (window.calendar) window.calendar.refetchEvents();
                            } else if (target === '#species-register') {
                                this.loadSpecies();
                            } else if (target === '#monitoring') {
                                this.loadMonitoring();
                            } else if (target === '#reports') {
                                this.loadReports();
                            } else if (target === '#legislation') {
                                this.loadComplianceChecklist();
                            } else if (target === '#settings') {
                                this.loadSettings();
                            }

                            // Refresh map when dashboard tab is shown
                            if (target === '#dashboard' && window.map) {
                                setTimeout(() => {
                                    window.map.invalidateSize(true);
                                }, 300);
                            }
                        });
                    });

                    const zoneToggle = document.getElementById('zoneToggle');
                    if (zoneToggle) {
                        zoneToggle.addEventListener('click', function() {
                            if (window.map) {
                                if (window.zonesLayer && window.map.hasLayer(window.zonesLayer)) {
                                    window.map.removeLayer(window.zonesLayer);
                                    if (window.customZonesLayer) window.map.removeLayer(window.customZonesLayer);
                                    this.classList.remove('active');
                                    this.setAttribute('aria-pressed', 'false');
                                } else {
                                    if (window.zonesLayer) window.map.addLayer(window.zonesLayer);
                                    if (window.customZonesLayer) window.map.addLayer(window.customZonesLayer);
                                    this.classList.add('active');
                                    this.setAttribute('aria-pressed', 'true');
                                }
                            }
                        });
                    }

                    const vegetationToggle = document.getElementById('vegetationToggle');
                    if (vegetationToggle) {
                        vegetationToggle.addEventListener('click', function() {
                            if (window.map) {
                                if (window.vegetationLayer && window.map.hasLayer(window.vegetationLayer)) {
                                    window.map.removeLayer(window.vegetationLayer);
                                    if (window.customVegetationLayer) window.map.removeLayer(window.customVegetationLayer);
                                    this.classList.remove('active');
                                    this.setAttribute('aria-pressed', 'false');
                                } else {
                                    if (window.vegetationLayer) window.map.addLayer(window.vegetationLayer);
                                    if (window.customVegetationLayer) window.map.addLayer(window.customVegetationLayer);
                                    this.classList.add('active');
                                    this.setAttribute('aria-pressed', 'true');
                                }
                            }
                        });
                    }

                    const weedsToggle = document.getElementById('weedsToggle');
                    if (weedsToggle) {
                        weedsToggle.addEventListener('click', function() {
                            if (window.map) {
                                if (window.weedsLayer && window.map.hasLayer(window.weedsLayer)) {
                                    window.map.removeLayer(window.weedsLayer);
                                    if (window.customWeedsLayer) window.map.removeLayer(window.customWeedsLayer);
                                    this.classList.remove('active');
                                    this.setAttribute('aria-pressed', 'false');
                                } else {
                                    if (window.weedsLayer) window.map.addLayer(window.weedsLayer);
                                    if (window.customWeedsLayer) window.map.addLayer(window.customWeedsLayer);
                                    this.classList.add('active');
                                    this.setAttribute('aria-pressed', 'true');
                                }
                            }
                        });
                    }

                    const speciesImage = document.getElementById('speciesImage');
                    if (speciesImage) {
                        speciesImage.addEventListener('change', function(e) {
                            const preview = document.getElementById('speciesImagePreview');
                            if (this.files && this.files[0] && preview) {
                                const url = URL.createObjectURL(this.files[0]);
                                preview.src = url;
                                preview.style.display = 'block';
                                
                                const modal = document.getElementById('modalNewSpecies');
                                modal.addEventListener('hidden.bs.modal', function() {
                                    URL.revokeObjectURL(url);
                                    preview.style.display = 'none';
                                }, { once: true });
                            }
                        });
                    }

                    ['assessment', 'monitoring', 'fauna', 'vegetation'].forEach(prefix => {
                        const input = document.getElementById(`${prefix}Photos`);
                        const container = document.getElementById(`${prefix}PhotoPreview`);
                        
                        if (input && container) {
                            input.addEventListener('change', function() {
                                container.innerHTML = '';
                                
                                Array.from(this.files).forEach(file => {
                                    if (file.type.startsWith('image/')) {
                                        const url = URL.createObjectURL(file);
                                        const img = document.createElement('img');
                                        img.src = url;
                                        img.className = 'image-thumbnail';
                                        img.alt = 'Preview';
                                        container.appendChild(img);
                                        
                                        const modal = this.closest('.modal');
                                        if (modal) {
                                            modal.addEventListener('hidden.bs.modal', function() {
                                                URL.revokeObjectURL(url);
                                            }, { once: true });
                                        }
                                    }
                                });
                            });
                        }
                    });

                    document.querySelectorAll('#formNewAssessment input[name="components"]').forEach(cb => {
                        cb.addEventListener('change', function() {
                            const checked = document.querySelectorAll('#formNewAssessment input[name="components"]:checked');
                            const feedback = document.getElementById('componentsFeedback');
                            if (feedback) {
                                feedback.style.display = checked.length === 0 ? 'block' : 'none';
                            }
                        });
                    });

                    document.querySelectorAll('.modal').forEach(modal => {
                        modal.addEventListener('hidden.bs.modal', function() {
                            const form = this.querySelector('form');
                            if (form) {
                                form.reset();
                                form.classList.remove('was-validated');
                            }
                            
                            this.querySelectorAll('.image-preview-container').forEach(container => {
                                container.innerHTML = '';
                            });
                            
                            const speciesPreview = this.querySelector('#speciesImagePreview');
                            if (speciesPreview) {
                                speciesPreview.style.display = 'none';
                                speciesPreview.src = '#';
                            }
                            
                            const feedback = this.querySelector('#componentsFeedback');
                            if (feedback) {
                                feedback.style.display = 'none';
                            }
                        });
                    });
                }
            };

            // ==================== INITIALIZE APPLICATION ====================
            document.addEventListener('DOMContentLoaded', function() {
                App.init();
            });

            // Expose global functions for onclick handlers
            window.generateReport = function(type) {
                App.generateReport(type);
            };

        })();
    </script>
