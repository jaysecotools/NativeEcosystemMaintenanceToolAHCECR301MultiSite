1. Fix for Grey Map

The map initialization has timing and dimension issues. Replace your initMap function with this improved version:

```javascript
initMap: function() {
    console.log('Initializing map...');
    
    const mapContainer = document.getElementById('map');
    if (!mapContainer) {
        console.error('Map element not found');
        return;
    }

    const siteId = db.currentSiteId;
    const site = Utils.getCurrentSite();
    
    if (!site) {
        mapContainer.innerHTML = '<div class="alert alert-warning">No site selected.</div>';
        return;
    }
    
    let mapData = db.siteMaps[siteId];
    if (!mapData) {
        mapData = Utils.generateSiteLocation(siteId);
        db.siteMaps[siteId] = mapData;
        Utils.saveData();
    }
    
    try {
        // Clean up existing map
        if (window.map) {
            window.map.remove();
            window.map = null;
        }
        
        // Ensure container has proper dimensions
        mapContainer.style.height = '500px';
        mapContainer.style.width = '100%';
        
        // Create new map
        window.map = L.map('map', {
            center: mapData.center,
            zoom: 13,
            zoomControl: true,
            fadeAnimation: false, // Disable animations for reliability
            zoomAnimation: false
        });

        // Add tile layer with error handling
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 19,
            detectRetina: true
        }).addTo(window.map);

        // Add main site marker
        L.marker(mapData.center).addTo(window.map)
            .bindPopup(`<b>${Utils.sanitizeHTML(site.name)}</b><br>${Utils.sanitizeHTML(site.location)}`)
            .openPopup();

        // Create layers
        this.createMapLayers(mapData);
        
        // Initialize editing tools
        this.initMapEditing();
        
        // Force map to recalculate size
        setTimeout(() => {
            if (window.map) {
                window.map.invalidateSize(true);
                console.log('Map size invalidated');
            }
        }, 250);
        
        // Additional resize on window resize
        window.addEventListener('resize', () => {
            if (window.map) {
                window.map.invalidateSize(true);
            }
        });
        
        console.log('Map initialized successfully');
        
    } catch (error) {
        console.error('Error initializing map:', error);
        mapContainer.innerHTML = '<div class="alert alert-warning">Map could not be loaded. Please check your internet connection.</div>';
    }
},

createMapLayers: function(mapData) {
    // Clear existing layers
    if (window.zonesLayer) window.zonesLayer.clearLayers();
    if (window.vegetationLayer) window.vegetationLayer.clearLayers();
    if (window.weedsLayer) window.weedsLayer.clearLayers();
    
    window.zonesLayer = L.layerGroup();
    window.vegetationLayer = L.layerGroup();
    window.weedsLayer = L.layerGroup();
    
    // Add zones
    mapData.zones.forEach(zone => {
        const polygon = L.polygon(zone.coords, {
            color: zone.color,
            weight: 2,
            opacity: 0.8,
            fillOpacity: 0.2
        }).bindPopup(`<b>${zone.name}</b>`);
        window.zonesLayer.addLayer(polygon);
    });
    
    // Add vegetation markers
    mapData.vegetationMarkers.forEach(markerData => {
        const marker = L.circleMarker(markerData.coords, {
            radius: 8,
            color: '#27ae60',
            fillColor: '#27ae60',
            fillOpacity: 0.8
        }).bindPopup(`<b>Vegetation:</b> ${markerData.name}`);
        window.vegetationLayer.addLayer(marker);
    });
    
    // Add weed markers
    mapData.weedMarkers.forEach(markerData => {
        const marker = L.circleMarker(markerData.coords, {
            radius: 8,
            color: '#e74c3c',
            fillColor: '#e74c3c',
            fillOpacity: 0.8
        }).bindPopup(`<b>Weed:</b> ${markerData.name}`);
        window.weedsLayer.addLayer(marker);
    });

    // Add zones layer by default
    window.zonesLayer.addTo(window.map);
    
    // Set button states
    const zoneToggle = document.getElementById('zoneToggle');
    const vegToggle = document.getElementById('vegetationToggle');
    const weedsToggle = document.getElementById('weedsToggle');
    
    if (zoneToggle) {
        zoneToggle.classList.add('active');
        zoneToggle.setAttribute('aria-pressed', 'true');
    }
    if (vegToggle) {
        vegToggle.classList.remove('active');
        vegToggle.setAttribute('aria-pressed', 'false');
    }
    if (weedsToggle) {
        weedsToggle.classList.remove('active');
        weedsToggle.setAttribute('aria-pressed', 'false');
    }
},

initMapEditing: function() {
    if (!window.map) return;
    
    try {
        // Initialize Leaflet Draw if available
        if (window.L && window.L.drawVersion) {
            const drawControl = new L.Control.Draw({
                draw: {
                    polygon: true,
                    polyline: true,
                    rectangle: true,
                    circle: true,
                    marker: true,
                    circlemarker: false
                },
                edit: {
                    featureGroup: new L.FeatureGroup()
                }
            });
            window.map.addControl(drawControl);
        }
    } catch (e) {
        console.warn('Drawing tools not available:', e);
    }
}
```

