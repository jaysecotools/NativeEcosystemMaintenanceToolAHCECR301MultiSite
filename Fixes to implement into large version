                    if (tasksList) {
                        tasksList.innerHTML = '';

                        if (upcomingTasks.length === 0) {
                            tasksList.innerHTML = `
                                <div class="empty-state">
                                    <i class="bi bi-check-circle"></i>
                                    <p>No upcoming tasks for this site</p>
                                </div>
                            `;
                        } else {
                            upcomingTasks
                                .sort((a, b) => new Date(a.startDate) - new Date(b.startDate))
                                .slice(0, 5)
                                .forEach(task => {
                                    const item = document.createElement('a');
                                    item.href = '#';
