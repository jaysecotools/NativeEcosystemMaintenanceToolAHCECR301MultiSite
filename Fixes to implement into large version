<script>
        (function() {
            'use strict';

            // ==================== CONSTANTS ====================
            const STORAGE_KEYS = {
                ASSESSMENTS: 'ecosystem_assessments',
                SPECIES: 'ecosystem_species',
                ACTIVITIES: 'ecosystem_activities',
                MONITORING: 'ecosystem_monitoring',
                REPORTS: 'ecosystem_reports',
                FAUNA_SIGHTINGS: 'ecosystem_fauna_sightings',
                VEGETATION_SURVEYS: 'ecosystem_vegetation_surveys',
                COMPLIANCE: 'ecosystem_compliance',
                SETTINGS: 'ecosystem_settings',
                SITES: 'ecosystem_sites',
                SITE_MAPS: 'ecosystem_site_maps',
                MAP_FEATURES: 'ecosystem_map_features'
            };

            // ==================== INITIAL DATA ====================
            const db = {
                assessments: [],
                species: [],
                activities: [],
                monitoring: [],
                reports: [],
                faunaSightings: [],
                vegetationSurveys: [],
                complianceChecklist: [
                    { id: 1, requirement: "Identified all relevant legislation", compliant: "", evidence: "", notes: "" },
                    { id: 2, requirement: "Assessed impacts on protected matters", compliant: "", evidence: "", notes: "" },
                    { id: 3, requirement: "Obtained necessary permits/approvals", compliant: "", evidence: "", notes: "" },
                    { id: 4, requirement: "Implemented required protections", compliant: "", evidence: "", notes: "" },
                    { id: 5, requirement: "Maintained required records", compliant: "", evidence: "", notes: "" }
                ],
                sites: [],
                siteMaps: {},
                mapFeatures: {},
                settings: {
                    userProfile: {
                        name: "John Doe",
                        email: "john.doe@example.com",
                        role: "ecologist"
                    }
                },
                currentSiteId: null,
                editMode: false
            };

            // ==================== UTILITY FUNCTIONS ====================
            const Utils = {
                parseJSON: function(key, defaultValue) {
                    try {
                        const item = localStorage.getItem(key);
                        return item ? JSON.parse(item) : defaultValue;
                    } catch (e) {
                        console.error(`Error parsing ${key}:`, e);
                        return defaultValue;
                    }
                },

                saveData: function() {
                    try {
                        localStorage.setItem(STORAGE_KEYS.ASSESSMENTS, JSON.stringify(db.assessments));
                        localStorage.setItem(STORAGE_KEYS.SPECIES, JSON.stringify(db.species));
                        localStorage.setItem(STORAGE_KEYS.ACTIVITIES, JSON.stringify(db.activities));
                        localStorage.setItem(STORAGE_KEYS.MONITORING, JSON.stringify(db.monitoring));
                        localStorage.setItem(STORAGE_KEYS.REPORTS, JSON.stringify(db.reports));
                        localStorage.setItem(STORAGE_KEYS.FAUNA_SIGHTINGS, JSON.stringify(db.faunaSightings));
                        localStorage.setItem(STORAGE_KEYS.VEGETATION_SURVEYS, JSON.stringify(db.vegetationSurveys));
                        localStorage.setItem(STORAGE_KEYS.COMPLIANCE, JSON.stringify(db.complianceChecklist));
                        localStorage.setItem(STORAGE_KEYS.SETTINGS, JSON.stringify(db.settings));
                        localStorage.setItem(STORAGE_KEYS.SITES, JSON.stringify(db.sites));
                        localStorage.setItem(STORAGE_KEYS.SITE_MAPS, JSON.stringify(db.siteMaps));
                        localStorage.setItem(STORAGE_KEYS.MAP_FEATURES, JSON.stringify(db.mapFeatures));
                        return true;
                    } catch (e) {
                        console.error('Error saving data:', e);
                        this.showToast('Error', 'Failed to save data. Storage may be full.', 'error');
                        return false;
                    }
                },

                loadData: function() {
                    db.assessments = this.parseJSON(STORAGE_KEYS.ASSESSMENTS, []);
                    db.species = this.parseJSON(STORAGE_KEYS.SPECIES, []);
                    db.activities = this.parseJSON(STORAGE_KEYS.ACTIVITIES, []);
                    db.monitoring = this.parseJSON(STORAGE_KEYS.MONITORING, []);
                    db.reports = this.parseJSON(STORAGE_KEYS.REPORTS, []);
                    db.faunaSightings = this.parseJSON(STORAGE_KEYS.FAUNA_SIGHTINGS, []);
                    db.vegetationSurveys = this.parseJSON(STORAGE_KEYS.VEGETATION_SURVEYS, []);
                    db.complianceChecklist = this.parseJSON(STORAGE_KEYS.COMPLIANCE, db.complianceChecklist);
                    db.settings = this.parseJSON(STORAGE_KEYS.SETTINGS, db.settings);
                    db.sites = this.parseJSON(STORAGE_KEYS.SITES, []);
                    db.siteMaps = this.parseJSON(STORAGE_KEYS.SITE_MAPS, {});
                    db.mapFeatures = this.parseJSON(STORAGE_KEYS.MAP_FEATURES, {});
                    
                    // Initialize mapFeatures for existing sites if needed
                    db.sites.forEach(site => {
                        if (!db.mapFeatures[site.id]) {
                            db.mapFeatures[site.id] = { zones: [], vegetation: [], weeds: [], points: [] };
                        }
                    });
                },

                sanitizeHTML: function(str) {
                    if (!str) return '';
                    const div = document.createElement('div');
                    div.textContent = str;
                    return div.innerHTML;
                },

                formatDate: function(dateString) {
                    if (!dateString) return 'Not specified';
                    try {
                        const date = new Date(dateString);
                        if (isNaN(date.getTime())) return 'Invalid date';
                        return date.toLocaleDateString('en-AU', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric'
                        });
                    } catch (e) {
                        return dateString;
                    }
                },

                formatDateTime: function(dateTimeString) {
                    if (!dateTimeString) return 'Not specified';
                    try {
                        const date = new Date(dateTimeString);
                        if (isNaN(date.getTime())) return 'Invalid date';
                        return date.toLocaleDateString('en-AU', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        });
                    } catch (e) {
                        return dateTimeString;
                    }
                },

                capitalize: function(str) {
                    if (!str) return '';
                    return str.charAt(0).toUpperCase() + str.slice(1);
                },

                showToast: function(title, message, type = 'success') {
                    const container = document.getElementById('toastContainer');
                    if (!container) return;

                    const toastId = 'toast-' + Date.now();
                    const bgClass = type === 'success' ? 'bg-success' :
                                   type === 'error' ? 'bg-danger' :
                                   type === 'warning' ? 'bg-warning' : 'bg-info';

                    const toastHtml = `
                        <div id="${toastId}" class="toast ${bgClass} text-white fade show" role="alert" aria-live="assertive" aria-atomic="true">
                            <div class="toast-header ${bgClass} text-white">
                                <strong class="me-auto">${Utils.sanitizeHTML(title)}</strong>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                            </div>
                            <div class="toast-body">
                                ${Utils.sanitizeHTML(message)}
                            </div>
                        </div>
                    `;

                    container.insertAdjacentHTML('beforeend', toastHtml);
                    const toastElement = document.getElementById(toastId);
                    const toast = new bootstrap.Toast(toastElement, { delay: 5000 });
                    toast.show();

                    toastElement.addEventListener('hidden.bs.toast', function() {
                        this.remove();
                    });
                },

                showConfirmation: function(title, message, onConfirm) {
                    const modalElement = document.getElementById('modalConfirm');
                    if (!modalElement) return;
                    
                    const modal = new bootstrap.Modal(modalElement);
                    const confirmBody = document.getElementById('confirmModalBody');
                    const confirmLabel = document.getElementById('modalConfirmLabel');
                    
                    if (confirmBody) confirmBody.innerHTML = this.sanitizeHTML(message);
                    if (confirmLabel) confirmLabel.innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i>${this.sanitizeHTML(title)}`;
                    
                    const confirmBtn = document.getElementById('confirmActionBtn');
                    if (!confirmBtn) return;
                    
                    const newBtn = confirmBtn.cloneNode(true);
                    confirmBtn.parentNode.replaceChild(newBtn, confirmBtn);
                    newBtn.id = 'confirmActionBtn';
                    
                    newBtn.addEventListener('click', function() {
                        onConfirm();
                        modal.hide();
                    });
                    
                    modal.show();
                },

                generateId: function() {
                    return Date.now() + Math.floor(Math.random() * 1000);
                },

                filterByCurrentSite: function(data) {
                    if (!db.currentSiteId) return [];
                    return data.filter(item => item.siteId === db.currentSiteId);
                },

                getCurrentSite: function() {
                    return db.sites.find(site => site.id === db.currentSiteId);
                },

                generateSiteLocation: function(siteId) {
                    const baseLat = -33.4000;
                    const baseLng = 150.3000;
                    
                    const idNum = typeof siteId === 'number' ? siteId : 
                                 (typeof siteId === 'string' ? parseInt(siteId) || 0 : 0);
                    
                    const latOffset = (idNum % 10) * 0.05;
                    const lngOffset = Math.floor(idNum / 10) % 10 * 0.05;
                    
                    return {
                        center: [baseLat + latOffset, baseLng + lngOffset],
                        zones: [
                            {
                                name: 'Zone 1 - Native Forest',
                                coords: [
                                    [baseLat - 0.01 + latOffset, baseLng - 0.01 + lngOffset],
                                    [baseLat - 0.01 + latOffset, baseLng + 0.01 + lngOffset],
                                    [baseLat + 0.01 + latOffset, baseLng + 0.01 + lngOffset],
                                    [baseLat + 0.01 + latOffset, baseLng - 0.01 + lngOffset]
                                ],
                                color: '#3498db'
                            },
                            {
                                name: 'Zone 2 - Wetland Area',
                                coords: [
                                    [baseLat + 0.02 + latOffset, baseLng - 0.015 + lngOffset],
                                    [baseLat + 0.02 + latOffset, baseLng + 0.005 + lngOffset],
                                    [baseLat + 0.04 + latOffset, baseLng + 0.005 + lngOffset],
                                    [baseLat + 0.04 + latOffset, baseLng - 0.015 + lngOffset]
                                ],
                                color: '#27ae60'
                            },
                            {
                                name: 'Zone 3 - Weed Control Area',
                                coords: [
                                    [baseLat - 0.03 + latOffset, baseLng + 0.02 + lngOffset],
                                    [baseLat - 0.03 + latOffset, baseLng + 0.04 + lngOffset],
                                    [baseLat - 0.01 + latOffset, baseLng + 0.04 + lngOffset],
                                    [baseLat - 0.01 + latOffset, baseLng + 0.02 + lngOffset]
                                ],
                                color: '#e74c3c'
                            }
                        ],
                        vegetationMarkers: [
                            { name: 'Eucalyptus pauciflora (Snow Gum)', coords: [baseLat - 0.005 + latOffset, baseLng + lngOffset] },
                            { name: 'Acacia melanoxylon (Blackwood)', coords: [baseLat - 0.004 + latOffset, baseLng + 0.002 + lngOffset] },
                            { name: 'Banksia marginata (Silver Banksia)', coords: [baseLat - 0.006 + latOffset, baseLng - 0.001 + lngOffset] }
                        ],
                        weedMarkers: [
                            { name: 'Rubus fruticosus (Blackberry)', coords: [baseLat - 0.025 + latOffset, baseLng + 0.025 + lngOffset] },
                            { name: 'Lantana camara (Lantana)', coords: [baseLat - 0.024 + latOffset, baseLng + 0.027 + lngOffset] },
                            { name: 'Ulex europaeus (Gorse)', coords: [baseLat - 0.026 + latOffset, baseLng + 0.026 + lngOffset] }
                        ]
                    };
                },

                getSiteHealthData: function(siteId) {
                    const siteAssessments = db.assessments.filter(a => a.siteId === siteId);
                    
                    let healthData = {
                        biodiversity: 78,
                        nativeCover: 65,
                        weedPressure: 22,
                        erosion: 15,
                        faunaActivity: 70,
                        waterQuality: 85,
                        previousBiodiversity: 72,
                        previousNativeCover: 60,
                        previousWeedPressure: 28,
                        previousErosion: 18,
                        previousFaunaActivity: 65,
                        previousWaterQuality: 80
                    };
                    
                    if (siteAssessments.length > 0) {
                        const sorted = [...siteAssessments].sort((a, b) => new Date(b.date) - new Date(a.date));
                        const latest = sorted[0];
                        const previous = sorted[1] || sorted[0];
                        
                        const healthScore = (health) => {
                            switch(health) {
                                case 'excellent': return 90;
                                case 'good': return 75;
                                case 'fair': return 55;
                                case 'poor': return 30;
                                case 'degraded': return 15;
                                default: return 50;
                            }
                        };
                        
                        const latestScore = healthScore(latest.health);
                        const previousScore = healthScore(previous.health);
                        
                        healthData = {
                            biodiversity: latestScore,
                            nativeCover: latestScore - (latest.threats && latest.threats.includes('weeds') ? 10 : 0),
                            weedPressure: 100 - latestScore + (latest.threats && latest.threats.includes('weeds') ? 20 : 10),
                            erosion: latest.threats && latest.threats.includes('erosion') ? 40 : 15,
                            faunaActivity: latestScore - 5,
                            waterQuality: latest.components && latest.components.includes('water') ? latestScore : 70,
                            previousBiodiversity: previousScore,
                            previousNativeCover: previousScore - (previous.threats && previous.threats.includes('weeds') ? 10 : 0),
                            previousWeedPressure: 100 - previousScore + (previous.threats && previous.threats.includes('weeds') ? 20 : 10),
                            previousErosion: previous.threats && previous.threats.includes('erosion') ? 40 : 15,
                            previousFaunaActivity: previousScore - 5,
                            previousWaterQuality: previous.components && previous.components.includes('water') ? previousScore : 70
                        };
                        
                        Object.keys(healthData).forEach(key => {
                            healthData[key] = Math.min(100, Math.max(0, healthData[key]));
                        });
                    }
                    
                    return healthData;
                }
            };

            // ==================== MAP EDITING FUNCTIONS ====================
            const MapEditor = {
                initEditing: function() {
                    if (!window.map) {
                        console.error('Map not initialized');
                        return;
                    }

                    // Initialize Leaflet Geoman for drawing/editing
                    if (window.map.pm) {
                        window.map.pm.addControls({
                            position: 'topleft',
                            drawMarker: true,
                            drawPolygon: true,
                            drawPolyline: true,
                            drawCircle: true,
                            drawRectangle: true,
                            editMode: true,
                            dragMode: true,
                            cutPolygon: true,
                            removalMode: true
                        });

                        // Set initial options
                        window.map.pm.setLang('en');
                        window.map.pm.setGlobalOptions({
                            snappable: false,
                            allowSelfIntersection: false
                        });

                        // Listen for created events
                        window.map.on('pm:create', (e) => {
                            this.onFeatureCreated(e);
                        });

                        // Listen for edit events
                        window.map.on('pm:edit', (e) => {
                            this.onFeatureEdited(e);
                        });

                        // Listen for remove events
                        window.map.on('pm:remove', (e) => {
                            this.onFeatureRemoved(e);
                        });
                    }

                    // Load existing features for current site
                    this.loadFeaturesForCurrentSite();

                    console.log('Map editing initialized');
                },

                loadFeaturesForCurrentSite: function() {
                    if (!db.currentSiteId) return;

                    const siteFeatures = db.mapFeatures[db.currentSiteId] || { zones: [], vegetation: [], weeds: [], points: [] };

                    // Clear existing custom layers
                    if (window.customZonesLayer) window.map.removeLayer(window.customZonesLayer);
                    if (window.customVegetationLayer) window.map.removeLayer(window.customVegetationLayer);
                    if (window.customWeedsLayer) window.map.removeLayer(window.customWeedsLayer);
                    if (window.customPointsLayer) window.map.removeLayer(window.customPointsLayer);

                    window.customZonesLayer = L.layerGroup();
                    window.customVegetationLayer = L.layerGroup();
                    window.customWeedsLayer = L.layerGroup();
                    window.customPointsLayer = L.layerGroup();

                    // Add zones
                    siteFeatures.zones.forEach(feature => {
                        if (feature.type === 'polygon') {
                            const polygon = L.polygon(feature.coordinates, {
                                color: feature.color || '#3498db',
                                weight: 3,
                                opacity: 0.8,
                                fillOpacity: 0.2
                            });
                            
                            polygon.featureData = feature;
                            polygon.bindPopup(this.createFeaturePopup(feature));
                            window.customZonesLayer.addLayer(polygon);
                        }
                    });

                    // Add vegetation markers
                    siteFeatures.vegetation.forEach(feature => {
                        const marker = L.marker(feature.coordinates, {
                            icon: L.divIcon({
                                className: 'custom-div-icon',
                                html: `<div style="background-color: ${feature.color || '#27ae60'}; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white;"></div>`,
                                iconSize: [16, 16],
                                popupAnchor: [0, -8]
                            })
                        });
                        
                        marker.featureData = feature;
                        marker.bindPopup(this.createFeaturePopup(feature));
                        window.customVegetationLayer.addLayer(marker);
                    });

                    // Add weed markers
                    siteFeatures.weeds.forEach(feature => {
                        const marker = L.marker(feature.coordinates, {
                            icon: L.divIcon({
                                className: 'custom-div-icon',
                                html: `<div style="background-color: ${feature.color || '#e74c3c'}; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white;"></div>`,
                                iconSize: [16, 16],
                                popupAnchor: [0, -8]
                            })
                        });
                        
                        marker.featureData = feature;
                        marker.bindPopup(this.createFeaturePopup(feature));
                        window.customWeedsLayer.addLayer(marker);
                    });

                    // Add points of interest
                    siteFeatures.points.forEach(feature => {
                        const marker = L.marker(feature.coordinates, {
                            icon: L.divIcon({
                                className: 'custom-div-icon',
                                html: `<div style="background-color: ${feature.color || '#f1c40f'}; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white;"></div>`,
                                iconSize: [16, 16],
                                popupAnchor: [0, -8]
                            })
                        });
                        
                        marker.featureData = feature;
                        marker.bindPopup(this.createFeaturePopup(feature));
                        window.customPointsLayer.addLayer(marker);
                    });

                    // Add layers to map based on toggle states
                    const zoneToggle = document.getElementById('zoneToggle');
                    const vegToggle = document.getElementById('vegetationToggle');
                    const weedsToggle = document.getElementById('weedsToggle');

                    if (zoneToggle && zoneToggle.classList.contains('active')) {
                        window.customZonesLayer.addTo(window.map);
                    }
                    if (vegToggle && vegToggle.classList.contains('active')) {
                        window.customVegetationLayer.addTo(window.map);
                    }
                    if (weedsToggle && weedsToggle.classList.contains('active')) {
                        window.customWeedsLayer.addTo(window.map);
                    }
                    
                    window.customPointsLayer.addTo(window.map);

                    this.updateMapFeaturesCount();
                },

                createFeaturePopup: function(feature) {
                    const species = feature.speciesId ? db.species.find(s => s.id === feature.speciesId) : null;
                    
                    return `
                        <div class="feature-popup">
                            <h6>${Utils.sanitizeHTML(feature.name)}</h6>
                            <p><strong>Category:</strong> ${Utils.capitalize(feature.category)}</p>
                            ${feature.description ? `<p>${Utils.sanitizeHTML(feature.description)}</p>` : ''}
                            ${species ? `<p><strong>Species:</strong> ${Utils.sanitizeHTML(species.scientificName)}</p>` : ''}
                            <button class="btn btn-sm btn-outline-primary edit-feature" data-id="${feature.id}">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                        </div>
                    `;
                },

                onFeatureCreated: function(e) {
                    if (!db.editMode) {
                        // If not in edit mode, remove the created feature
                        window.map.pm.removeLayer(e.layer);
                        Utils.showToast('Info', 'Enable Edit Mode to add features', 'info');
                        return;
                    }

                    const layer = e.layer;
                    const shape = e.shape;

                    // Determine feature type
                    let featureType = 'point';
                    if (shape === 'Polygon' || shape === 'Rectangle' || shape === 'Circle') {
                        featureType = 'polygon';
                    } else if (shape === 'Line') {
                        featureType = 'line';
                    } else {
                        featureType = 'point';
                    }

                    // Get coordinates
                    let coordinates;
                    if (featureType === 'polygon') {
                        coordinates = layer.getLatLngs()[0].map(latlng => [latlng.lat, latlng.lng]);
                    } else if (featureType === 'line') {
                        coordinates = layer.getLatLngs().map(latlng => [latlng.lat, latlng.lng]);
                    } else {
                        const latlng = layer.getLatLng();
                        coordinates = [latlng.lat, latlng.lng];
                    }

                    // Store feature data temporarily
                    layer.featureData = {
                        id: Utils.generateId(),
                        type: featureType,
                        coordinates: coordinates,
                        category: 'point-of-interest',
                        name: 'New Feature',
                        description: '',
                        color: '#f1c40f',
                        speciesId: null,
                        createdAt: new Date().toISOString()
                    };

                    // Open modal to edit feature details
                    this.showAddFeatureModal(layer);
                },

                onFeatureEdited: function(e) {
                    if (!db.editMode) return;

                    const layer = e.layer;
                    if (layer.featureData) {
                        // Update coordinates based on new shape
                        if (layer.featureData.type === 'polygon') {
                            layer.featureData.coordinates = layer.getLatLngs()[0].map(latlng => [latlng.lat, latlng.lng]);
                        } else if (layer.featureData.type === 'line') {
                            layer.featureData.coordinates = layer.getLatLngs().map(latlng => [latlng.lat, latlng.lng]);
                        } else {
                            const latlng = layer.getLatLng();
                            layer.featureData.coordinates = [latlng.lat, latlng.lng];
                        }
                        
                        layer.featureData.updatedAt = new Date().toISOString();
                    }
                },

                onFeatureRemoved: function(e) {
                    if (!db.editMode) return;

                    const layer = e.layer;
                    if (layer.featureData) {
                        this.removeFeatureFromStorage(layer.featureData.id);
                    }
                },

                showAddFeatureModal: function(layer) {
                    const modal = document.getElementById('modalAddMapFeature');
                    if (!modal) return;

                    // Clear form
                    document.getElementById('formAddMapFeature').reset();
                    
                    // Set feature type
                    document.getElementById('featureType').value = layer.featureData.type;
                    
                    // Set coordinates
                    if (layer.featureData.type === 'polygon' || layer.featureData.type === 'line') {
                        document.getElementById('featureCoordinates').value = JSON.stringify(layer.featureData.coordinates);
                    } else {
                        document.getElementById('featureLat').value = layer.featureData.coordinates[0];
                        document.getElementById('featureLng').value = layer.featureData.coordinates[1];
                    }

                    // Populate species dropdown
                    this.populateSpeciesDropdown('featureSpecies');

                    // Set up color picker
                    this.setupColorPicker('colorPickerContainer', 'featureColor');

                    // Store layer reference
                    modal.currentLayer = layer;

                    new bootstrap.Modal(modal).show();
                },

                showEditFeatureModal: function(featureId) {
                    const feature = this.findFeatureById(featureId);
                    if (!feature) return;

                    const modal = document.getElementById('modalEditMapFeature');
                    if (!modal) return;

                    // Fill form
                    document.getElementById('editFeatureId').value = feature.id;
                    document.getElementById('editFeatureLayerId').value = feature.layerId || '';
                    document.getElementById('editFeatureName').value = feature.name;
                    document.getElementById('editFeatureCategory').value = feature.category;
                    document.getElementById('editFeatureDescription').value = feature.description || '';
                    document.getElementById('editFeatureColor').value = feature.color || '#3498db';

                    // Populate species dropdown
                    this.populateSpeciesDropdown('editFeatureSpecies', feature.speciesId);

                    // Set up color picker
                    this.setupColorPicker('editColorPickerContainer', 'editFeatureColor', feature.color);

                    // Store feature reference
                    modal.currentFeature = feature;

                    new bootstrap.Modal(modal).show();
                },

                populateSpeciesDropdown: function(selectId, selectedId) {
                    const select = document.getElementById(selectId);
                    if (!select) return;

                    select.innerHTML = '<option value="">None</option>';
                    
                    Utils.filterByCurrentSite(db.species).forEach(species => {
                        const option = document.createElement('option');
                        option.value = species.id;
                        option.textContent = `${species.scientificName}${species.commonName ? ` (${species.commonName})` : ''}`;
                        if (selectedId && species.id === selectedId) {
                            option.selected = true;
                        }
                        select.appendChild(option);
                    });
                },

                setupColorPicker: function(containerId, inputId, defaultColor = '#3498db') {
                    const container = document.getElementById(containerId);
                    const input = document.getElementById(inputId);
                    
                    if (!container || !input) return;

                    // Set default
                    input.value = defaultColor;

                    // Add click handlers to color pickers
                    container.querySelectorAll('.color-picker').forEach(picker => {
                        picker.classList.remove('selected');
                        if (picker.dataset.color === defaultColor) {
                            picker.classList.add('selected');
                        }

                        picker.addEventListener('click', function() {
                            container.querySelectorAll('.color-picker').forEach(p => p.classList.remove('selected'));
                            this.classList.add('selected');
                            input.value = this.dataset.color;
                        });
                    });
                },

                saveNewFeature: function() {
                    const form = document.getElementById('formAddMapFeature');
                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    const category = document.getElementById('featureCategory').value;
                    const name = document.getElementById('featureName').value;
                    const description = document.getElementById('featureDescription').value;
                    const color = document.getElementById('featureColor').value;
                    const speciesId = document.getElementById('featureSpecies').value || null;
                    const featureType = document.getElementById('featureType').value;

                    // Get coordinates
                    let coordinates;
                    if (featureType === 'polygon' || featureType === 'line') {
                        coordinates = JSON.parse(document.getElementById('featureCoordinates').value);
                    } else {
                        const lat = parseFloat(document.getElementById('featureLat').value);
                        const lng = parseFloat(document.getElementById('featureLng').value);
                        coordinates = [lat, lng];
                    }

                    // Create feature object
                    const feature = {
                        id: Utils.generateId(),
                        siteId: db.currentSiteId,
                        type: featureType,
                        category: category,
                        name: name,
                        description: description,
                        color: color,
                        speciesId: speciesId,
                        coordinates: coordinates,
                        createdAt: new Date().toISOString()
                    };

                    // Store in database
                    if (!db.mapFeatures[db.currentSiteId]) {
                        db.mapFeatures[db.currentSiteId] = { zones: [], vegetation: [], weeds: [], points: [] };
                    }

                    // Add to appropriate category
                    if (category === 'zone') {
                        db.mapFeatures[db.currentSiteId].zones.push(feature);
                    } else if (category === 'vegetation') {
                        db.mapFeatures[db.currentSiteId].vegetation.push(feature);
                    } else if (category === 'weed') {
                        db.mapFeatures[db.currentSiteId].weeds.push(feature);
                    } else {
                        db.mapFeatures[db.currentSiteId].points.push(feature);
                    }

                    // Update the layer with feature data
                    const modal = document.getElementById('modalAddMapFeature');
                    if (modal.currentLayer) {
                        modal.currentLayer.featureData = feature;
                        
                        // Update popup
                        modal.currentLayer.unbindPopup();
                        modal.currentLayer.bindPopup(this.createFeaturePopup(feature));
                    }

                    // Save to storage
                    if (Utils.saveData()) {
                        bootstrap.Modal.getInstance(modal).hide();
                        Utils.showToast('Success', 'Feature added to map');
                        this.updateMapFeaturesCount();
                    }
                },

                updateFeature: function() {
                    const form = document.getElementById('formEditMapFeature');
                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    const featureId = parseInt(document.getElementById('editFeatureId').value);
                    const feature = this.findFeatureById(featureId);
                    
                    if (!feature) return;

                    // Update properties
                    feature.name = document.getElementById('editFeatureName').value;
                    feature.category = document.getElementById('editFeatureCategory').value;
                    feature.description = document.getElementById('editFeatureDescription').value;
                    feature.color = document.getElementById('editFeatureColor').value;
                    feature.speciesId = document.getElementById('editFeatureSpecies').value || null;
                    feature.updatedAt = new Date().toISOString();

                    // Find and update the layer
                    this.updateLayerForFeature(feature);

                    // Save to storage
                    if (Utils.saveData()) {
                        bootstrap.Modal.getInstance(document.getElementById('modalEditMapFeature')).hide();
                        Utils.showToast('Success', 'Feature updated');
                        this.updateMapFeaturesCount();
                    }
                },

                deleteFeature: function() {
                    const featureId = parseInt(document.getElementById('editFeatureId').value);
                    
                    Utils.showConfirmation(
                        'Delete Feature',
                        'Are you sure you want to delete this map feature?',
                        () => {
                            this.removeFeatureFromStorage(featureId);
                            
                            // Find and remove the layer
                            this.removeLayerForFeature(featureId);
                            
                            bootstrap.Modal.getInstance(document.getElementById('modalEditMapFeature')).hide();
                            Utils.showToast('Success', 'Feature deleted');
                            this.updateMapFeaturesCount();
                        }
                    );
                },

                findFeatureById: function(featureId) {
                    const siteFeatures = db.mapFeatures[db.currentSiteId] || { zones: [], vegetation: [], weeds: [], points: [] };
                    
                    for (const category of ['zones', 'vegetation', 'weeds', 'points']) {
                        const feature = siteFeatures[category].find(f => f.id === featureId);
                        if (feature) return feature;
                    }
                    
                    return null;
                },

                removeFeatureFromStorage: function(featureId) {
                    const siteFeatures = db.mapFeatures[db.currentSiteId];
                    if (!siteFeatures) return;

                    for (const category of ['zones', 'vegetation', 'weeds', 'points']) {
                        const index = siteFeatures[category].findIndex(f => f.id === featureId);
                        if (index !== -1) {
                            siteFeatures[category].splice(index, 1);
                            break;
                        }
                    }

                    Utils.saveData();
                },

                updateLayerForFeature: function(feature) {
                    this.loadFeaturesForCurrentSite();
                },

                removeLayerForFeature: function(featureId) {
                    this.loadFeaturesForCurrentSite();
                },

                updateMapFeaturesCount: function() {
                    const siteFeatures = db.mapFeatures[db.currentSiteId] || { zones: [], vegetation: [], weeds: [], points: [] };
                    const total = siteFeatures.zones.length + siteFeatures.vegetation.length + 
                                 siteFeatures.weeds.length + siteFeatures.points.length;
                    
                    const mapFeaturesCount = document.getElementById('mapFeaturesCount');
                    if (mapFeaturesCount) mapFeaturesCount.textContent = total;
                },

                toggleEditMode: function() {
                    db.editMode = !db.editMode;
                    
                    const editModeBtn = document.getElementById('editModeBtn');
                    const mapEditMode = document.getElementById('mapEditMode');
                    
                    if (editModeBtn) {
                        if (db.editMode) {
                            editModeBtn.classList.add('active', 'btn-warning');
                            editModeBtn.classList.remove('btn-outline-warning');
                            editModeBtn.innerHTML = '<i class="bi bi-pencil-square"></i> Exit Edit Mode';
                            if (mapEditMode) mapEditMode.textContent = 'Edit Mode';
                        } else {
                            editModeBtn.classList.remove('active', 'btn-warning');
                            editModeBtn.classList.add('btn-outline-warning');
                            editModeBtn.innerHTML = '<i class="bi bi-pencil-square"></i> Edit Mode';
                            if (mapEditMode) mapEditMode.textContent = 'View Mode';
                        }
                    }

                    if (window.map && window.map.pm) {
                        if (db.editMode) {
                            window.map.pm.enableDraw('Marker');
                        } else {
                            window.map.pm.disableDraw();
                            window.map.pm.disableGlobalEditMode();
                        }
                    }

                    Utils.showToast('Info', db.editMode ? 'Edit mode enabled' : 'Edit mode disabled', 'info');
                },

                saveMap: function() {
                    if (Utils.saveData()) {
                        Utils.showToast('Success', 'Map saved successfully');
                    }
                },

                clearMap: function() {
                    Utils.showConfirmation(
                        'Clear Map',
                        'Are you sure you want to clear all custom map features? This cannot be undone.',
                        () => {
                            // Clear features for current site
                            db.mapFeatures[db.currentSiteId] = { zones: [], vegetation: [], weeds: [], points: [] };
                            
                            // Reload features (which will clear layers)
                            this.loadFeaturesForCurrentSite();
                            
                            Utils.saveData();
                            Utils.showToast('Success', 'Map cleared');
                        }
