3. Fix for Site Switching to Ensure Chart Updates

Update the switchSite function in SiteManager:

```javascript
switchSite: function(siteId) {
    // Save current site data
    Utils.saveData();
    
    // Update current site
    db.currentSiteId = siteId;
    
    // Update UI
    this.loadSiteSelector();
    App.populateModalSiteIds();
    
    // Force chart update first
    setTimeout(() => {
        App.updateHealthChart();
    }, 100);
    
    // Then load all data
    setTimeout(() => {
        App.loadAllData();
    }, 200);
    
    // Update map
    setTimeout(() => {
        if (window.map) {
            App.initMap(); // Reinitialize map completely
        } else {
            App.initMap();
        }
    }, 300);
    
    bootstrap.Modal.getInstance(document.getElementById('modalSwitchSite')).hide();
    
    const site = db.sites.find(s => s.id === siteId);
    Utils.showToast('Success', 'Switched to ' + (site ? site.name : 'site'));
}
```

