 initMap: function() {
    console.log('Initializing map...');
    
    const mapContainer = document.getElementById('map');
    if (!mapContainer) {
        console.error('Map element not found');
        return;
    }

    // Check if Leaflet is loaded
    if (typeof L === 'undefined') {
        console.error('Leaflet not loaded');
        mapContainer.innerHTML = '<div class="alert alert-danger">Leaflet library failed to load. Check internet connection.</div>';
        return;
    }

    const siteId = db.currentSiteId;
    const site = Utils.getCurrentSite();
    
    if (!site) {
        mapContainer.innerHTML = '<div class="alert alert-warning">No site selected.</div>';
        return;
    }
    
    // Clean up existing map
    if (window.map) {
        try {
            window.map.remove();
        } catch (e) {
            console.warn('Error removing existing map:', e);
        }
        window.map = null;
    }
    
    // Clear container
    mapContainer.innerHTML = '';
    
    // Get map data
    let mapData = db.siteMaps[siteId];
    if (!mapData) {
        mapData = {
            center: [-33.7, 150.3], // Blue Mountains default
            zones: [],
            vegetationMarkers: [],
            weedMarkers: []
        };
        db.siteMaps[siteId] = mapData;
    }
    
    try {

        // Create new map instance
        window.map = L.map('map', {
            center: mapData.center || [-33.7, 150.3],
            zoom: 12,
            zoomControl: true
        });

        // Add tile layer
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 19
        }).addTo(window.map);

        // Add site marker
        L.marker(mapData.center || [-33.7, 150.3])
            .addTo(window.map)
            .bindPopup(`<b>${Utils.sanitizeHTML(site.name)}</b>`)
            .openPopup();

        // Create layer groups
        window.zonesLayer = L.layerGroup();
        window.vegetationLayer = L.layerGroup();
        window.weedsLayer = L.layerGroup();

        // Add sample zones if none exist
        if (!mapData.zones || mapData.zones.length === 0) {
            this.addSampleZones(mapData);
        }

        // Add zones to map
        if (mapData.zones && mapData.zones.length > 0) {
            mapData.zones.forEach(zone => {
                if (zone && zone.coords) {
                    const polygon = L.polygon(zone.coords, {
                        color: zone.color || '#3498db',
                        weight: 2,
                        opacity: 0.8,
                        fillOpacity: 0.2
                    }).bindPopup(`<b>${Utils.sanitizeHTML(zone.name)}</b>`);
                    window.zonesLayer.addLayer(polygon);
                }
            });
        }

        // Add vegetation markers
        if (mapData.vegetationMarkers && mapData.vegetationMarkers.length > 0) {
            mapData.vegetationMarkers.forEach(marker => {
                if (marker && marker.coords) {
                    const m = L.marker(marker.coords, {
                        icon: L.divIcon({
                            className: 'veg-marker',
                            html: '<div style="background-color: #27ae60; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white;"></div>',
                            iconSize: [16, 16]
                        })
                    }).bindPopup(`<b>${Utils.sanitizeHTML(marker.name)}</b>`);
                    window.vegetationLayer.addLayer(m);
                }
            });
        }

        // Add weed markers
        if (mapData.weedMarkers && mapData.weedMarkers.length > 0) {
            mapData.weedMarkers.forEach(marker => {
                if (marker && marker.coords) {
                    const m = L.marker(marker.coords, {
                        icon: L.divIcon({
                            className: 'weed-marker',
                            html: '<div style="background-color: #e74c3c; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white;"></div>',
                            iconSize: [16, 16]
                        })
                    }).bindPopup(`<b>${Utils.sanitizeHTML(marker.name)}</b>`);
                    window.weedsLayer.addLayer(m);
                }
            });
        }

        // Add layers to map
        window.zonesLayer.addTo(window.map);
        
        // Initialize custom layers for editable features
        window.customZonesLayer = L.layerGroup();
        window.customVegetationLayer = L.layerGroup();
        window.customWeedsLayer = L.layerGroup();
        window.customPointsLayer = L.layerGroup();
        
        // Load custom features
        MapEditor.loadFeaturesForCurrentSite();
        
        // Initialize editing tools if available
        if (window.map.pm) {
            try {
                window.map.pm.addControls({
                    position: 'topleft',
                    drawMarker: true,
                    drawPolygon: true,
                    drawPolyline: true,
                    drawCircle: true,
                    drawRectangle: true,
                    editMode: true,
                    dragMode: true,
                    cutPolygon: true,
                    removalMode: true
                });
                
                // Set initial edit mode state
                if (db.editMode) {
                    window.map.pm.enableDraw('Marker');
                } else {
                    window.map.pm.disableDraw();
                }
            } catch (e) {
                console.warn('Geoman controls failed:', e);
            }
        }

        // Set button states
        const zoneToggle = document.getElementById('zoneToggle');
        const vegToggle = document.getElementById('vegetationToggle');
        const weedsToggle = document.getElementById('weedsToggle');
        const editModeBtn = document.getElementById('editModeBtn');
        const mapEditMode = document.getElementById('mapEditMode');
        
        if (zoneToggle) {
            zoneToggle.classList.add('active');
            zoneToggle.setAttribute('aria-pressed', 'true');
        }
        if (vegToggle) {
            vegToggle.classList.remove('active');
            vegToggle.setAttribute('aria-pressed', 'false');
        }
        if (weedsToggle) {
            weedsToggle.classList.remove('active');
            weedsToggle.setAttribute('aria-pressed', 'false');
        }
        if (editModeBtn && mapEditMode) {
            if (db.editMode) {
                editModeBtn.classList.add('active', 'btn-warning');
                editModeBtn.classList.remove('btn-outline-warning');
                editModeBtn.innerHTML = '<i class="bi bi-pencil-square"></i> Exit Edit Mode';
                mapEditMode.textContent = 'Edit Mode';
            } else {
                editModeBtn.classList.remove('active', 'btn-warning');
                editModeBtn.classList.add('btn-outline-warning');
                editModeBtn.innerHTML = '<i class="bi bi-pencil-square"></i> Edit Mode';
                mapEditMode.textContent = 'View Mode';
            }
        }

        // CRITICAL: Force map to recalculate size
        setTimeout(() => {
            if (window.map) {
                window.map.invalidateSize(true);
                console.log('Map size invalidated');
            }
        }, 300);

        // Also invalidate on window resize
        window.addEventListener('resize', function onResize() {
            if (window.map && document.getElementById('dashboard') && 
                document.getElementById('dashboard').classList.contains('show')) {
                window.map.invalidateSize();
            }
        });

        console.log('Map initialized successfully');
        
    } catch (error) {
        console.error('Map initialization error:', error);
        mapContainer.innerHTML = '<div class="alert alert-danger">Map failed to load. See console for details.</div>';
    }
},

