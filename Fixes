// ==================== SIMPLE MAP FUNCTIONS ====================
const SimpleMap = {
    map: null,
    marker: null,
    sitePins: {},

    initMap: function() {
        console.log('Initializing simple map...');
        
        const mapElement = document.getElementById('map');
        if (!mapElement) {
            console.error('Map element not found');
            return;
        }

        const site = Utils.getCurrentSite();
        if (!site) {
            mapElement.innerHTML = '<div class="alert alert-warning">No site selected.</div>';
            return;
        }
        
        // Get saved pin or use default
        let lat = -33.4000;
        let lng = 150.3000;
        
        // Load saved pins
        try {
            const savedPins = localStorage.getItem('site_pins');
            if (savedPins) {
                this.sitePins = JSON.parse(savedPins);
                if (this.sitePins[site.id]) {
                    lat = this.sitePins[site.id].lat;
                    lng = this.sitePins[site.id].lng;
                }
            }
        } catch (e) {
            console.error('Error loading pins:', e);
        }

        try {
            // Clear existing map
            if (this.map) {
                this.map.remove();
                this.map = null;
            }
            
            // Clear container
            mapElement.innerHTML = '';
            
            // Create map
            this.map = L.map('map', {
                center: [lat, lng],
                zoom: 13,
                zoomControl: true
            });

            // Add tiles
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap'
            }).addTo(this.map);

            // Add marker
            this.marker = L.marker([lat, lng]).addTo(this.map)
                .bindPopup(`<b>${site.name}</b><br>${site.location}`)
                .openPopup();

            // Force resize after a short delay
            setTimeout(() => {
                if (this.map) {
                    this.map.invalidateSize(true);
                    console.log('Map resized');
                }
            }, 200);

            console.log('Map initialized successfully');

        } catch (error) {
            console.error('Map error:', error);
            mapElement.innerHTML = '<div class="alert alert-danger">Map could not be loaded. Please check your internet connection.</div>';
        }
    },

    addPin: function() {
        const site = Utils.getCurrentSite();
        if (!site) {
            alert('No site selected');
            return;
        }

        // Get current position
        const currentPos = this.marker ? this.marker.getLatLng() : { lat: -33.4000, lng: 150.3000 };
        
        // Prompt for coordinates (simple approach)
        const lat = prompt('Enter latitude:', currentPos.lat);
        if (lat === null) return;
        
        const lng = prompt('Enter longitude:', currentPos.lng);
        if (lng === null) return;
        
        const newLat = parseFloat(lat);
        const newLng = parseFloat(lng);
        
        if (isNaN(newLat) || isNaN(newLng)) {
            alert('Invalid coordinates');
            return;
        }

        // Update marker
        if (this.marker) {
            this.marker.setLatLng([newLat, newLng]);
        } else {
            this.marker = L.marker([newLat, newLng]).addTo(this.map)
                .bindPopup(`<b>${site.name}</b><br>${site.location}`);
        }
        
        this.map.setView([newLat, newLng], this.map.getZoom());

        // Save pin
        this.sitePins[site.id] = { lat: newLat, lng: newLng };
        localStorage.setItem('site_pins', JSON.stringify(this.sitePins));
        
        alert('Pin saved successfully');
    },

    removePin: function() {
        const site = Utils.getCurrentSite();
        if (!site) return;

        if (confirm('Remove site pin?')) {
            if (this.marker) {
                this.map.removeLayer(this.marker);
                this.marker = null;
            }
            
            delete this.sitePins[site.id];
            localStorage.setItem('site_pins', JSON.stringify(this.sitePins));
            
            alert('Pin removed');
        }
    }
};
